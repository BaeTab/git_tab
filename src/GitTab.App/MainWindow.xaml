<Window x:Class="GitTab.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:GitTab.App.Controls"
        xmlns:beh="clr-namespace:GitTab.App.Behaviors"
        xmlns:loc="clr-namespace:GitTab.App.Localization"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        Title="{loc:Tr App.Title}"
        Icon="pack://application:,,,/GitTab;component/Assets/gittab.ico"
        Height="760" Width="1220" MinHeight="480" MinWidth="900"
        AllowDrop="True" DragOver="OnDragOver" Drop="OnDrop"
        Background="{DynamicResource Brush.Window}"
        TextOptions.TextFormattingMode="Ideal"
        FontFamily="Segoe UI" FontSize="13">

    <!-- Keyboard shortcuts are user-customizable: MainWindow.xaml.cs builds Window.InputBindings at
         runtime from KeybindingService (saved overrides, or the built-in defaults), and rebuilds them
         whenever the user changes a binding in the Keybindings dialog. See RebuildShortcuts(). -->

    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="40" ResizeBorderThickness="6" CornerRadius="0"
                            GlassFrameThickness="0" UseAeroCaptionButtons="False"/>
    </shell:WindowChrome.WindowChrome>

    <DockPanel LastChildFill="True">
        <!-- ================= Custom title bar ================= -->
        <Border DockPanel.Dock="Top" Height="40" Background="{DynamicResource Brush.Surface}"
                BorderBrush="{DynamicResource Brush.Border}" BorderThickness="0,0,0,1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center" Margin="12,0">
                    <Image Source="pack://application:,,,/GitTab;component/Assets/gittab.ico" Width="18" Height="18"
                           Margin="0,0,8,0" RenderOptions.BitmapScalingMode="HighQuality"/>
                    <TextBlock Text="{loc:Tr App.Title}" FontWeight="SemiBold" VerticalAlignment="Center"/>
                </StackPanel>
                <StackPanel Grid.Column="2" Orientation="Horizontal">
                    <Button Style="{StaticResource TitleBarButton}" Content="&#xE921;" Click="OnMinimize"
                            AutomationProperties.Name="Minimize"/>
                    <Button x:Name="MaxRestoreButton" Style="{StaticResource TitleBarButton}" Content="&#xE922;" Click="OnMaxRestore"
                            AutomationProperties.Name="Maximize / Restore"/>
                    <Button Style="{StaticResource TitleBarCloseButton}" Content="&#xE8BB;" Click="OnCloseWindow"
                            AutomationProperties.Name="{loc:Tr Common.Close}"/>
                </StackPanel>
            </Grid>
        </Border>

        <Grid>
        <!-- UI/font zoom for accessibility: scales the whole content area (title bar excluded). -->
        <Grid.LayoutTransform>
            <ScaleTransform ScaleX="{Binding UiScale}" ScaleY="{Binding UiScale}"/>
        </Grid.LayoutTransform>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>   <!-- toolbar -->
            <RowDefinition Height="Auto"/>   <!-- repository tabs -->
            <RowDefinition Height="Auto"/>   <!-- conflict / bisect banners -->
            <RowDefinition Height="*"/>      <!-- main content -->
            <RowDefinition Height="Auto"/>   <!-- status bar -->
        </Grid.RowDefinitions>

        <!-- ================= Toolbar ================= -->
        <Border Grid.Row="0" Background="{DynamicResource Brush.Surface}"
                BorderBrush="{DynamicResource Brush.Border}" BorderThickness="0,0,0,1" Padding="8,6">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Primary + network + search live in a WrapPanel so that on a narrow window they
                     wrap to a second row instead of being clipped; secondary/management actions are
                     already folded into the overflow (≡) menu. The right-hand controls stay pinned. -->
                <WrapPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                <StackPanel Orientation="Horizontal">
                    <Button Style="{StaticResource AccentButton}" Command="{Binding OpenRepositoryCommand}"
                            ToolTip="{loc:Tr Action.Open.Tip}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE838;" FontFamily="Segoe MDL2 Assets" FontSize="12"
                                       VerticalAlignment="Center" Margin="0,0,7,0"/>
                            <TextBlock Text="{loc:Tr Action.Open}" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <Button Style="{StaticResource ToolButton}" Command="{Binding CreateRepositoryCommand}"
                            ToolTip="{loc:Tr Repo.Create.Tip}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE710;" FontFamily="Segoe MDL2 Assets" FontSize="12"
                                       VerticalAlignment="Center" Margin="0,0,6,0"/>
                            <TextBlock Text="{loc:Tr Repo.Create}" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <Button Style="{StaticResource ToolButton}" Command="{Binding CloneCommand}"
                            ToolTip="{loc:Tr Clone.Tip}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE896;" FontFamily="Segoe MDL2 Assets" FontSize="12"
                                       VerticalAlignment="Center" Margin="0,0,6,0"/>
                            <TextBlock Text="{loc:Tr Clone.Action}" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <Menu Background="Transparent" VerticalAlignment="Center" Margin="2,0">
                        <MenuItem ItemsSource="{Binding RecentRepositories}">
                            <MenuItem.Header>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#xE81C;" FontFamily="Segoe MDL2 Assets" FontSize="11"
                                               VerticalAlignment="Center" Margin="0,0,6,0" Foreground="{DynamicResource Brush.TextMuted}"/>
                                    <TextBlock Text="{loc:Tr Action.Recent}" VerticalAlignment="Center"/>
                                    <TextBlock Text="&#xE70D;" FontFamily="Segoe MDL2 Assets" FontSize="8"
                                               VerticalAlignment="Center" Margin="6,1,0,0" Foreground="{DynamicResource Brush.TextMuted}"/>
                                </StackPanel>
                            </MenuItem.Header>
                            <MenuItem.ItemContainerStyle>
                                <Style TargetType="MenuItem">
                                    <Setter Property="Header" Value="{Binding Name}"/>
                                    <Setter Property="ToolTip" Value="{Binding Path}"/>
                                    <Setter Property="Command"
                                            Value="{Binding DataContext.OpenRecentCommand, RelativeSource={RelativeSource AncestorType=Window}}"/>
                                    <Setter Property="CommandParameter" Value="{Binding}"/>
                                </Style>
                            </MenuItem.ItemContainerStyle>
                        </MenuItem>
                    </Menu>
                    <Button Style="{StaticResource ToolButton}" Command="{Binding ActiveSession.RefreshCommand}"
                            Content="&#xE72C;" FontFamily="Segoe MDL2 Assets" FontSize="13" ToolTip="{loc:Tr Action.Refresh.Tip}"
                            AutomationProperties.Name="{loc:Tr Action.Refresh}"/>

                    <!-- Overflow menu: every secondary/management action, so the toolbar never scrolls. -->
                    <Menu Background="Transparent" VerticalAlignment="Center" Margin="2,0"
                          Visibility="{Binding IsRepositoryOpen, Converter={StaticResource Bool2Vis}}">
                        <MenuItem Foreground="{DynamicResource Brush.Text}" ToolTip="{loc:Tr Menu.Tools.Tip}"
                                  AutomationProperties.Name="{loc:Tr Menu.Tools}">
                            <MenuItem.Header>
                                <TextBlock Text="&#xE712;" FontFamily="Segoe MDL2 Assets" FontSize="14"/>
                            </MenuItem.Header>
                            <MenuItem Header="{loc:Tr Reflog.Title}" Command="{Binding ActiveSession.OpenReflogCommand}"/>
                            <MenuItem Header="{loc:Tr Compare.Title}" Command="{Binding ActiveSession.CompareCommand}"/>
                            <MenuItem Header="{loc:Tr Search.Content}" Command="{Binding ActiveSession.ContentSearchCommand}"/>
                            <Separator/>
                            <MenuItem Header="{loc:Tr Remote.Manage}" Command="{Binding ActiveSession.ManageRemotesCommand}"/>
                            <MenuItem Header="{loc:Tr Gitignore.Title}" Command="{Binding ActiveSession.GenerateGitignoreCommand}"/>
                            <Separator/>
                            <MenuItem Header="{loc:Tr Menu.Worktrees}" Command="{Binding ActiveSession.ManageWorktreesCommand}"/>
                            <MenuItem Header="{loc:Tr Menu.Lfs}" Command="{Binding ActiveSession.ManageLfsCommand}"/>
                            <MenuItem Header="{loc:Tr Menu.Submodules}" Command="{Binding ActiveSession.ManageSubmodulesCommand}"/>
                            <MenuItem Header="{loc:Tr Menu.Sparse}" Command="{Binding ActiveSession.ManageSparseCheckoutCommand}"/>
                            <Separator/>
                            <MenuItem Header="{loc:Tr Patch.Apply}" Command="{Binding ActiveSession.ApplyPatchCommand}"/>
                            <MenuItem Header="{loc:Tr Menu.Credentials}" Command="{Binding ManageCredentialsCommand}"/>
                            <MenuItem Header="{loc:Tr Menu.Keybindings}" Command="{Binding OpenKeybindingsCommand}"/>
                            <Separator/>
                            <MenuItem Header="{loc:Tr Menu.Hosting}" Command="{Binding ActiveSession.OpenHostingCommand}"/>
                            <MenuItem Header="{loc:Tr Menu.OpenInEditor}" Command="{Binding ActiveSession.OpenInEditorCommand}"/>
                            <MenuItem Header="{loc:Tr Menu.Statistics}" Command="{Binding ActiveSession.ShowStatisticsCommand}"/>
                            <MenuItem Header="{loc:Tr Menu.Changelog}" Command="{Binding ActiveSession.GenerateChangelogCommand}"/>
                            <MenuItem Header="{loc:Tr Menu.Config}" Command="{Binding ActiveSession.EditConfigCommand}"/>
                            <MenuItem Header="{loc:Tr Menu.ForcePush}" Command="{Binding ActiveSession.ForcePushCommand}"/>
                            <MenuItem Header="{loc:Tr Menu.Bookmarks}" ItemsSource="{Binding ActiveSession.Bookmarks}">
                                <MenuItem.ItemContainerStyle>
                                    <Style TargetType="MenuItem">
                                        <Setter Property="Header" Value="{Binding Summary}"/>
                                        <Setter Property="Command" Value="{Binding DataContext.ActiveSession.JumpToBookmarkCommand, RelativeSource={RelativeSource AncestorType=Menu}}"/>
                                        <Setter Property="CommandParameter" Value="{Binding}"/>
                                    </Style>
                                </MenuItem.ItemContainerStyle>
                            </MenuItem>
                            <MenuItem Header="{loc:Tr Submodule.Update}" Command="{Binding ActiveSession.SubmoduleUpdateCommand}"
                                      Visibility="{Binding ActiveSession.HasSubmodules, Converter={StaticResource Bool2Vis}}"/>
                        </MenuItem>
                    </Menu>
                </StackPanel>

                <!-- remote actions -->
                <StackPanel Orientation="Horizontal" Margin="4,0"
                            Visibility="{Binding IsRepositoryOpen, Converter={StaticResource Bool2Vis}}">
                    <Border Style="{StaticResource ToolbarSeparator}"/>
                    <Border CornerRadius="7" Padding="9,3" Margin="4,0" BorderThickness="1"
                            VerticalAlignment="Center" ToolTip="{loc:Tr Remote.AheadBehind.Tip}">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Background" Value="{DynamicResource Brush.SurfaceAlt}"/>
                                <Setter Property="BorderBrush" Value="Transparent"/>
                                <Style.Triggers>
                                    <!-- Background fetch found commits to pull → nudge with an accent outline. -->
                                    <DataTrigger Binding="{Binding ActiveSession.HasIncoming}" Value="True">
                                        <Setter Property="Background" Value="{DynamicResource Brush.Selection}"/>
                                        <Setter Property="BorderBrush" Value="{DynamicResource Brush.Accent}"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE896;" FontFamily="Segoe MDL2 Assets" FontSize="10" VerticalAlignment="Center"
                                       Foreground="{DynamicResource Brush.TextMuted}" Margin="0,0,6,0"/>
                            <TextBlock Text="{Binding ActiveSession.CurrentBranchName}" FontWeight="SemiBold" VerticalAlignment="Center"/>
                            <TextBlock VerticalAlignment="Center" Margin="8,0,0,0" Style="{StaticResource MutedText}" FontSize="11">
                                <Run Text="↑"/><Run Text="{Binding ActiveSession.Ahead}"/><Run Text=" ↓"/><Run Text="{Binding ActiveSession.Behind}"/>
                            </TextBlock>
                        </StackPanel>
                    </Border>
                    <Border Style="{StaticResource ToolbarSeparator}"/>
                    <Button Style="{StaticResource IconTextButton}" Tag="&#xE895;" Command="{Binding ActiveSession.FetchCommand}"
                            Content="{loc:Tr Action.Fetch}" ToolTip="{loc:Tr Action.Fetch.Tip}"/>
                    <Button Style="{StaticResource IconTextButton}" Tag="&#xE896;" Command="{Binding ActiveSession.PullCommand}"
                            Content="{loc:Tr Action.Pull}" ToolTip="{loc:Tr Action.Pull.Tip}"/>
                    <Button Style="{StaticResource IconTextButton}" Tag="&#xE898;" Command="{Binding ActiveSession.PushCommand}"
                            Content="{loc:Tr Action.Push}" ToolTip="{loc:Tr Action.Push.Tip}"/>
                    <Border Style="{StaticResource ToolbarSeparator}"/>
                    <Button Style="{StaticResource IconTextButton}" Tag="&#xE8A7;" Command="{Binding ActiveSession.CreatePullRequestCommand}"
                            Content="{loc:Tr Hosting.PR}" ToolTip="{loc:Tr Hosting.PR.Tip}"/>
                    <Button Style="{StaticResource ToolButton}" Command="{Binding ActiveSession.OpenRemoteWebCommand}"
                            Content="&#xE774;" FontFamily="Segoe MDL2 Assets" FontSize="13" ToolTip="{loc:Tr Hosting.Web.Tip}"
                            AutomationProperties.Name="{loc:Tr Hosting.Web}"/>
                </StackPanel>

                <!-- search -->
                <Grid Width="220" Margin="8,0" VerticalAlignment="Center"
                      Visibility="{Binding IsRepositoryOpen, Converter={StaticResource Bool2Vis}}">
                    <TextBox x:Name="SearchBox" Text="{Binding ActiveSession.SearchText, UpdateSourceTrigger=PropertyChanged, Delay=150}"
                             ToolTip="{loc:Tr Search.Tip}"/>
                    <TextBlock Text="{loc:Tr Search.Placeholder}" Style="{StaticResource MutedText}"
                               Margin="10,0" VerticalAlignment="Center" IsHitTestVisible="False"
                               Visibility="{Binding ActiveSession.SearchText, Converter={StaticResource HasValue2Vis}, ConverterParameter=invert}"/>
                </Grid>
                </WrapPanel>

                <!-- language / theme / update / settings (always visible, pinned right) -->
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <Border Style="{StaticResource ToolbarSeparator}"/>
                    <Button Style="{StaticResource ToolButton}" Command="{Binding ToggleLanguageCommand}"
                            Content="한 / EN" ToolTip="{loc:Tr Language}"/>
                    <Button Style="{StaticResource ToolButton}" Command="{Binding ToggleThemeCommand}"
                            Content="&#xE706;" FontFamily="Segoe MDL2 Assets" FontSize="13" ToolTip="{loc:Tr Theme.Toggle}"
                            AutomationProperties.Name="{loc:Tr Theme.Toggle}"/>
                    <Button Style="{StaticResource ToolButton}" Command="{Binding CheckUpdatesCommand}"
                            Content="&#xE896;" FontFamily="Segoe MDL2 Assets" FontSize="13" ToolTip="{loc:Tr Update.Checking}"
                            AutomationProperties.Name="{loc:Tr Update.Checking}"/>
                    <Button Style="{StaticResource ToolButton}" Command="{Binding OpenSettingsCommand}"
                            Content="&#xE713;" FontFamily="Segoe MDL2 Assets" FontSize="13" ToolTip="{loc:Tr Settings}"
                            AutomationProperties.Name="{loc:Tr Settings}"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ================= Repository tabs ================= -->
        <Border Grid.Row="1" Background="{DynamicResource Brush.Surface}"
                BorderBrush="{DynamicResource Brush.Border}" BorderThickness="0,0,0,1" Padding="6,3"
                Visibility="{Binding IsRepositoryOpen, Converter={StaticResource Bool2Vis}}">
            <ListBox ItemsSource="{Binding Sessions}" SelectedItem="{Binding ActiveSession}"
                     Background="Transparent" BorderThickness="0"
                     ScrollViewer.HorizontalScrollBarVisibility="Auto" ScrollViewer.VerticalScrollBarVisibility="Disabled">
                <ListBox.ItemsPanel>
                    <ItemsPanelTemplate><StackPanel Orientation="Horizontal"/></ItemsPanelTemplate>
                </ListBox.ItemsPanel>
                <ListBox.ItemContainerStyle>
                    <Style TargetType="ListBoxItem">
                        <Setter Property="Margin" Value="0,0,4,0"/>
                        <Setter Property="Padding" Value="0"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ListBoxItem">
                                    <Border x:Name="bd" CornerRadius="6" Padding="10,4"
                                            Background="{DynamicResource Brush.SurfaceAlt}">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="&#xE81C;" FontFamily="Segoe MDL2 Assets" FontSize="10"
                                                       VerticalAlignment="Center" Margin="0,0,6,0"
                                                       Foreground="{DynamicResource Brush.TextMuted}"/>
                                            <TextBlock Text="{Binding RepositoryName}" VerticalAlignment="Center"
                                                       Foreground="{DynamicResource Brush.Text}"/>
                                            <Button Content="&#xE711;" FontFamily="Segoe MDL2 Assets" FontSize="9"
                                                    Margin="8,0,0,0" Padding="3,1" VerticalAlignment="Center"
                                                    Background="Transparent" BorderThickness="0" Cursor="Hand"
                                                    Foreground="{DynamicResource Brush.TextMuted}"
                                                    ToolTip="{loc:Tr Tab.Close}"
                                                    Command="{Binding DataContext.CloseTabCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                    CommandParameter="{Binding}"/>
                                        </StackPanel>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter TargetName="bd" Property="Background" Value="{DynamicResource Brush.Accent}"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </ListBox.ItemContainerStyle>
            </ListBox>
        </Border>

        <!-- ================= Conflict / in-progress operation banner ================= -->
        <Border Grid.Row="2" Background="{DynamicResource Brush.SurfaceAlt}"
                BorderBrush="{DynamicResource Brush.Danger}" BorderThickness="0,0,0,2" Padding="14,9"
                DataContext="{Binding ActiveSession}"
                Visibility="{Binding IsOperationInProgress, Converter={StaticResource Bool2Vis}, FallbackValue=Collapsed}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                    <TextBlock Text="{Binding OperationName}" FontWeight="Bold" Foreground="{DynamicResource Brush.Danger}"/>
                    <TextBlock Text="{loc:Tr Conflict.Hint}" Style="{StaticResource MutedText}" TextWrapping="Wrap"/>
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Content="{loc:Tr Conflict.Continue}" Style="{StaticResource AccentButton}" Margin="0,0,8,0"
                            Command="{Binding ContinueOperationCommand}"/>
                    <Button Content="{loc:Tr Conflict.Abort}" Command="{Binding AbortOperationCommand}"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ================= Bisect banner ================= -->
        <Border Grid.Row="2" Background="{DynamicResource Brush.SurfaceAlt}"
                BorderBrush="{DynamicResource Brush.Accent}" BorderThickness="0,0,0,2" Padding="14,9"
                DataContext="{Binding ActiveSession}"
                Visibility="{Binding IsBisecting, Converter={StaticResource Bool2Vis}, FallbackValue=Collapsed}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                    <TextBlock Text="{loc:Tr Bisect.Title}" FontWeight="Bold" Foreground="{DynamicResource Brush.Accent}"/>
                    <TextBlock Text="{Binding BisectStatus}" Style="{StaticResource MutedText}" TextWrapping="Wrap"
                               FontFamily="Consolas" FontSize="11.5" MaxHeight="60"/>
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Content="{loc:Tr Bisect.Good}" Style="{StaticResource AccentButton}" Margin="0,0,6,0"
                            Command="{Binding BisectGoodCommand}" ToolTip="{loc:Tr Bisect.Good.Tip}"/>
                    <Button Content="{loc:Tr Bisect.Bad}" Margin="0,0,6,0"
                            Command="{Binding BisectBadCommand}" ToolTip="{loc:Tr Bisect.Bad.Tip}"/>
                    <Button Content="{loc:Tr Bisect.Skip}" Margin="0,0,6,0" Command="{Binding BisectSkipCommand}"/>
                    <Button Content="{loc:Tr Bisect.Reset}" Command="{Binding BisectResetCommand}"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ================= Main content (scoped to the active repository session) ================= -->
        <Grid Grid.Row="3" Margin="8" DataContext="{Binding ActiveSession}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="270" MinWidth="200"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*" MinWidth="520"/>
            </Grid.ColumnDefinitions>

            <!-- ===== Left: Changes / Branches ===== -->
            <Border Grid.Column="0" Style="{StaticResource Card}">
                <TabControl x:Name="LeftTabs" Background="Transparent" BorderThickness="0">
                    <!-- Changes / staging -->
                    <TabItem Header="{loc:Tr Panel.Changes}" DataContext="{Binding WorkingCopy}">
                        <Grid Margin="4">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <!-- unstaged -->
                            <DockPanel Grid.Row="0">
                                <Grid DockPanel.Dock="Top">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="{loc:Tr WC.Unstaged}" Style="{StaticResource SectionHeader}"
                                               TextTrimming="CharacterEllipsis" VerticalAlignment="Center"/>
                                    <Button Grid.Column="1" Content="+" Style="{StaticResource ToolButton}" VerticalAlignment="Center"
                                            Command="{Binding StageAllCommand}" ToolTip="{loc:Tr WC.StageAll.Tip}"/>
                                </Grid>
                                <ListBox ItemsSource="{Binding Unstaged}" SelectedItem="{Binding SelectedFile}">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <Grid ToolTip="{Binding DisplayPath}"
                                                  Tag="{Binding DataContext, RelativeSource={RelativeSource AncestorType=Window}}">
                                                <Grid.ContextMenu>
                                                    <ContextMenu>
                                                        <MenuItem Header="{loc:Tr Conflict.Resolve}"
                                                                  Command="{Binding PlacementTarget.Tag.ResolveConflictCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                                  CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                                                        <MenuItem Header="{loc:Tr FileHistory.Menu}"
                                                                  Command="{Binding PlacementTarget.Tag.FileHistoryCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                                  CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                                                        <MenuItem Header="{loc:Tr Blame}"
                                                                  Command="{Binding PlacementTarget.Tag.BlameCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                                  CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                                                        <Separator/>
                                                        <MenuItem Header="{loc:Tr Ctx.OpenInEditor}"
                                                                  Command="{Binding PlacementTarget.Tag.OpenFileInEditorCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                                  CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                                                        <MenuItem Header="{loc:Tr Ctx.ExternalDiff}"
                                                                  Command="{Binding PlacementTarget.Tag.ExternalDiffCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                                  CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                                                        <Separator/>
                                                        <MenuItem Header="{loc:Tr Ctx.AddToGitignore}"
                                                                  Command="{Binding PlacementTarget.Tag.AddToGitignoreCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                                  CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                                                    </ContextMenu>
                                                </Grid.ContextMenu>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0" Text="{Binding StatusLetter}" Width="16" FontWeight="Bold"
                                                           Foreground="{Binding StatusColorKey, Converter={StaticResource Key2Brush}}"/>
                                                <TextBlock Grid.Column="1" Text="{Binding DisplayPath}" TextTrimming="CharacterEllipsis"/>
                                                <StackPanel Grid.Column="2" Orientation="Horizontal">
                                                    <Button Content="±" Style="{StaticResource ToolButton}" Padding="6,0"
                                                            Command="{Binding DataContext.StagePartialCommand, RelativeSource={RelativeSource AncestorType=ListBox}}"
                                                            CommandParameter="{Binding}" ToolTip="{loc:Tr WC.StagePartial.Tip}"
                                                            AutomationProperties.Name="{loc:Tr WC.StagePartial}"/>
                                                    <Button Content="+" Style="{StaticResource ToolButton}" Padding="6,0"
                                                            Command="{Binding DataContext.StageCommand, RelativeSource={RelativeSource AncestorType=ListBox}}"
                                                            CommandParameter="{Binding}" ToolTip="{loc:Tr WC.Stage.Tip}"/>
                                                    <Button Content="" FontFamily="Segoe MDL2 Assets" FontSize="12" Style="{StaticResource ToolButton}" Padding="6,0"
                                                            Command="{Binding DataContext.DiscardCommand, RelativeSource={RelativeSource AncestorType=ListBox}}"
                                                            CommandParameter="{Binding}" ToolTip="{loc:Tr WC.Discard.Tip}"/>
                                                </StackPanel>
                                            </Grid>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                            </DockPanel>

                            <!-- staged -->
                            <DockPanel Grid.Row="1">
                                <Grid DockPanel.Dock="Top">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="{loc:Tr WC.Staged}" Style="{StaticResource SectionHeader}"
                                               TextTrimming="CharacterEllipsis" VerticalAlignment="Center"/>
                                    <Button Grid.Column="1" Content="−" Style="{StaticResource ToolButton}" VerticalAlignment="Center"
                                            Command="{Binding UnstageAllCommand}" ToolTip="{loc:Tr WC.UnstageAll}"/>
                                </Grid>
                                <ListBox ItemsSource="{Binding Staged}" SelectedItem="{Binding SelectedFile}">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <Grid ToolTip="{Binding DisplayPath}">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0" Text="{Binding StatusLetter}" Width="16" FontWeight="Bold"
                                                           Foreground="{Binding StatusColorKey, Converter={StaticResource Key2Brush}}"/>
                                                <TextBlock Grid.Column="1" Text="{Binding DisplayPath}" TextTrimming="CharacterEllipsis"/>
                                                <Button Grid.Column="2" Content="−" Style="{StaticResource ToolButton}" Padding="6,0"
                                                        Command="{Binding DataContext.UnstageCommand, RelativeSource={RelativeSource AncestorType=ListBox}}"
                                                        CommandParameter="{Binding}" ToolTip="{loc:Tr WC.Unstage.Tip}"/>
                                            </Grid>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                            </DockPanel>

                            <!-- commit box -->
                            <StackPanel Grid.Row="2" Margin="6,6">
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                    <TextBlock Text="{loc:Tr WC.Type}" VerticalAlignment="Center" Margin="0,0,6,0"
                                               Foreground="{DynamicResource Brush.TextMuted}"/>
                                    <ComboBox ItemsSource="{Binding CommitTypes}" SelectedItem="{Binding SelectedCommitType}"
                                              MinWidth="130" ToolTip="{loc:Tr WC.Type.Tip}"/>
                                </StackPanel>
                                <TextBox Text="{Binding CommitMessage, UpdateSourceTrigger=PropertyChanged}"
                                         AcceptsReturn="True" TextWrapping="Wrap" MinHeight="54" MaxHeight="120"
                                         VerticalScrollBarVisibility="Auto"
                                         ToolTip="{loc:Tr WC.Commit.Tip}"/>
                                <CheckBox Content="{loc:Tr WC.Amend}" IsChecked="{Binding Amend}" Margin="0,8,0,0"
                                          Foreground="{DynamicResource Brush.Text}" ToolTip="{loc:Tr WC.Amend.Tip}"/>
                                <CheckBox Content="{loc:Tr Commit.Sign}" IsChecked="{Binding Sign}" Margin="0,4,0,0"
                                          Foreground="{DynamicResource Brush.Text}"/>
                                <CheckBox Content="{loc:Tr WC.SignOff}" IsChecked="{Binding SignOff}" Margin="0,4,0,0"
                                          Foreground="{DynamicResource Brush.Text}"/>
                                <Button HorizontalAlignment="Left" Style="{StaticResource ToolButton}" Margin="0,4,0,0" Padding="0,2"
                                        Content="{loc:Tr CoAuthor.Add}" Command="{Binding AddCoAuthorCommand}"
                                        Foreground="{DynamicResource Brush.Accent}"/>
                                <Button HorizontalAlignment="Stretch" Style="{StaticResource AccentButton}" Margin="0,8,0,0"
                                        Content="{loc:Tr WC.Commit}" Command="{Binding CommitCommand}"
                                        ToolTip="{loc:Tr WC.Commit.Tip}"/>
                                <TextBlock Text="{loc:Tr WC.Clean}" Style="{StaticResource MutedText}" Margin="2,6,0,0"
                                           TextWrapping="Wrap"
                                           Visibility="{Binding IsClean, Converter={StaticResource Bool2Vis}}"/>
                            </StackPanel>
                        </Grid>
                    </TabItem>

                    <!-- Branches -->
                    <TabItem Header="{loc:Tr Panel.Branches}" DataContext="{Binding Branches}">
                        <ScrollViewer VerticalScrollBarVisibility="Auto" Margin="2">
                            <StackPanel>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="{loc:Tr Branch.Local}" Style="{StaticResource SectionHeader}"
                                               TextTrimming="CharacterEllipsis" VerticalAlignment="Center"/>
                                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                        <Button Content="&#xE74D;" FontFamily="Segoe MDL2 Assets" FontSize="11" Style="{StaticResource ToolButton}"
                                                Command="{Binding PruneMergedCommand}" ToolTip="{loc:Tr Branch.PruneMerged.Tip}"/>
                                        <Button Content="+" Style="{StaticResource ToolButton}"
                                                Command="{Binding NewBranchCommand}" ToolTip="{loc:Tr Branch.New.Tip}"/>
                                    </StackPanel>
                                </Grid>
                                <ListBox ItemsSource="{Binding Local}" SelectedItem="{Binding SelectedBranch}">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <Grid Tag="{Binding DataContext, RelativeSource={RelativeSource AncestorType=ListBox}}">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <Grid.ContextMenu>
                                                    <ContextMenu>
                                                        <MenuItem Header="{loc:Tr Branch.Checkout}"
                                                                  Command="{Binding PlacementTarget.Tag.CheckoutCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                                  CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                                                        <MenuItem Header="{loc:Tr Branch.Merge}"
                                                                  Command="{Binding PlacementTarget.Tag.MergeCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                                  CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                                                        <MenuItem Header="{loc:Tr Branch.Rebase}"
                                                                  Command="{Binding PlacementTarget.Tag.RebaseCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                                  CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                                                        <Separator/>
                                                        <MenuItem Header="{loc:Tr Branch.Rename}"
                                                                  Command="{Binding PlacementTarget.Tag.RenameCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                                  CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                                                        <MenuItem Header="{loc:Tr Branch.Delete}"
                                                                  Command="{Binding PlacementTarget.Tag.DeleteCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                                  CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                                                    </ContextMenu>
                                                </Grid.ContextMenu>
                                                <TextBlock Grid.Column="0" Text="{Binding FriendlyName}" TextTrimming="CharacterEllipsis">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock" BasedOn="{StaticResource {x:Type TextBlock}}">
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsCurrent}" Value="True">
                                                                    <Setter Property="FontWeight" Value="Bold"/>
                                                                    <Setter Property="Foreground" Value="{DynamicResource Brush.Accent}"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                                <TextBlock Grid.Column="1" Text="{Binding AheadBehindText}" Style="{StaticResource MutedText}" FontSize="11"/>
                                            </Grid>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>

                                <TextBlock Text="{loc:Tr Branch.Remote}" Style="{StaticResource SectionHeader}"/>
                                <ListBox ItemsSource="{Binding Remote}" SelectedItem="{Binding SelectedBranch}">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <Grid Tag="{Binding DataContext, RelativeSource={RelativeSource AncestorType=ListBox}}">
                                                <Grid.ContextMenu>
                                                    <ContextMenu>
                                                        <MenuItem Header="{loc:Tr Branch.Checkout}"
                                                                  Command="{Binding PlacementTarget.Tag.CheckoutCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                                  CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                                                        <MenuItem Header="{loc:Tr Branch.Merge}"
                                                                  Command="{Binding PlacementTarget.Tag.MergeCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                                  CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                                                        <Separator/>
                                                        <MenuItem Header="{loc:Tr Ctx.DeleteRemote}"
                                                                  Command="{Binding PlacementTarget.Tag.DeleteRemoteCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                                  CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                                                    </ContextMenu>
                                                </Grid.ContextMenu>
                                                <TextBlock Text="{Binding FriendlyName}" TextTrimming="CharacterEllipsis"
                                                           Style="{StaticResource MutedText}"/>
                                            </Grid>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>

                                <!-- Tags -->
                                <TextBlock Text="{loc:Tr Tag.Section}" Style="{StaticResource SectionHeader}"/>
                                <ListBox ItemsSource="{Binding Tags}">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <Grid Tag="{Binding DataContext, RelativeSource={RelativeSource AncestorType=ListBox}}">
                                                <Grid.ContextMenu>
                                                    <ContextMenu>
                                                        <MenuItem Header="{loc:Tr Tag.Push}"
                                                                  Command="{Binding PlacementTarget.Tag.PushTagCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                                  CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                                                        <MenuItem Header="{loc:Tr Tag.Delete}"
                                                                  Command="{Binding PlacementTarget.Tag.DeleteTagCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                                  CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                                                    </ContextMenu>
                                                </Grid.ContextMenu>
                                                <TextBlock Text="{Binding Name}" TextTrimming="CharacterEllipsis"/>
                                            </Grid>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>

                                <!-- Stashes (owned by MainViewModel) -->
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="{loc:Tr Stash.Section}" Style="{StaticResource SectionHeader}"
                                               VerticalAlignment="Center"/>
                                    <Button Grid.Column="1" Content="+" Style="{StaticResource ToolButton}" VerticalAlignment="Center"
                                            Command="{Binding DataContext.StashPushCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                            ToolTip="{loc:Tr Stash.Push.Tip}"/>
                                </Grid>
                                <ListBox ItemsSource="{Binding DataContext.Stashes, RelativeSource={RelativeSource AncestorType=Window}}">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <Grid Tag="{Binding DataContext, RelativeSource={RelativeSource AncestorType=Window}}"
                                                  ToolTip="{Binding Message}">
                                                <Grid.ContextMenu>
                                                    <ContextMenu>
                                                        <MenuItem Header="{loc:Tr Stash.Pop}"
                                                                  Command="{Binding PlacementTarget.Tag.StashPopCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                                  CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                                                        <MenuItem Header="{loc:Tr Stash.Apply}"
                                                                  Command="{Binding PlacementTarget.Tag.StashApplyCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                                  CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                                                        <MenuItem Header="{loc:Tr Stash.Drop}"
                                                                  Command="{Binding PlacementTarget.Tag.StashDropCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                                  CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                                                        <Separator/>
                                                        <MenuItem Header="{loc:Tr Ctx.StashDiff}"
                                                                  Command="{Binding PlacementTarget.Tag.StashDiffCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                                  CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                                                        <MenuItem Header="{loc:Tr Ctx.StashToBranch}"
                                                                  Command="{Binding PlacementTarget.Tag.StashToBranchCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                                  CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                                                    </ContextMenu>
                                                </Grid.ContextMenu>
                                                <TextBlock Text="{Binding Message}" TextTrimming="CharacterEllipsis"/>
                                            </Grid>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                            </StackPanel>
                        </ScrollViewer>
                    </TabItem>
                </TabControl>
            </Border>

            <GridSplitter Grid.Column="1" Width="6" HorizontalAlignment="Center" Background="Transparent"
                          VerticalAlignment="Stretch"/>

            <!-- ===== Right of sidebar: graph (top) + commit details (bottom) ===== -->
            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" MinHeight="160"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="360" MinHeight="140"/>
                </Grid.RowDefinitions>

            <!-- ===== Graph ===== -->
            <Border Grid.Row="0" Style="{StaticResource Card}" ClipToBounds="True">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <controls:CommitGraphHeader Grid.Row="0" LaneCount="{Binding LaneCount}"
                                                Visibility="{Binding IsRepositoryOpen, Converter={StaticResource Bool2Vis}, FallbackValue=Collapsed}"/>

                    <ScrollViewer Grid.Row="1" CanContentScroll="True" VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled"
                                  Visibility="{Binding IsRepositoryOpen, Converter={StaticResource Bool2Vis}, FallbackValue=Collapsed}">
                        <controls:CommitGraphControl
                            x:Name="CommitGraph"
                            Rows="{Binding Rows}"
                            LaneCount="{Binding LaneCount}"
                            StatsSource="{Binding Stats}"
                            AutomationProperties.Name="{loc:Tr Panel.History}"
                            KeyboardNavigation.TabIndex="0"
                            SelectedIndex="{Binding SelectedCommitIndex, Mode=TwoWay}">
                            <controls:CommitGraphControl.ContextMenu>
                                <ContextMenu DataContext="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource Self}}">
                                    <MenuItem Header="{loc:Tr Ctx.CheckoutCommit}" Command="{Binding CheckoutCommitCommand}"/>
                                    <MenuItem Header="{loc:Tr Ctx.Bookmark}" Command="{Binding ToggleBookmarkCommand}"/>
                                    <MenuItem Header="{loc:Tr Ctx.Reword}" Command="{Binding RewordCommitCommand}"/>
                                    <MenuItem Header="{loc:Tr Ctx.AmendAuthor}" Command="{Binding AmendAuthorCommand}"/>
                                    <MenuItem Header="{loc:Tr Ctx.StartBisect}" Command="{Binding StartBisectCommand}"/>
                                    <MenuItem Header="{loc:Tr Ctx.CreateBranch}" Command="{Binding CreateBranchHereCommand}"/>
                                    <MenuItem Header="{loc:Tr Ctx.CreateTag}" Command="{Binding CreateTagHereCommand}"/>
                                    <Separator/>
                                    <MenuItem Header="{loc:Tr Ctx.Revert}" Command="{Binding RevertCommitCommand}"/>
                                    <MenuItem Header="{loc:Tr Ctx.CherryPick}" Command="{Binding CherryPickCommand}"/>
                                    <MenuItem Header="{loc:Tr Ctx.InteractiveRebase}" Command="{Binding InteractiveRebaseCommand}"/>
                                    <MenuItem Header="{loc:Tr Ctx.ExportPatch}" Command="{Binding ExportPatchCommand}"/>
                                    <Separator/>
                                    <MenuItem Header="{loc:Tr Ctx.ResetSoft}" Command="{Binding ResetSoftCommand}"/>
                                    <MenuItem Header="{loc:Tr Ctx.ResetMixed}" Command="{Binding ResetMixedCommand}"/>
                                    <MenuItem Header="{loc:Tr Ctx.ResetHard}" Command="{Binding ResetHardCommand}"/>
                                    <Separator/>
                                    <MenuItem Header="{loc:Tr Ctx.CopySha}" Command="{Binding CopyShaCommand}"/>
                                    <MenuItem Header="{loc:Tr Ctx.CopyMessage}" Command="{Binding CopyMessageCommand}"/>
                                </ContextMenu>
                            </controls:CommitGraphControl.ContextMenu>
                        </controls:CommitGraphControl>
                    </ScrollViewer>

                    <!-- welcome / empty state (bound to the app shell, since it shows when no session is active) -->
                    <StackPanel Grid.Row="0" Grid.RowSpan="2" VerticalAlignment="Center" HorizontalAlignment="Center" MaxWidth="420"
                                DataContext="{Binding DataContext, RelativeSource={RelativeSource AncestorType=Window}}"
                                Visibility="{Binding IsRepositoryOpen, Converter={StaticResource Bool2Vis}, ConverterParameter=invert}">
                        <TextBlock Text="{loc:Tr Welcome.Title}" FontSize="22" FontWeight="Bold" HorizontalAlignment="Center"/>
                        <TextBlock Text="{loc:Tr Welcome.Subtitle}" Style="{StaticResource MutedText}" TextWrapping="Wrap"
                                   TextAlignment="Center" Margin="0,8"/>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,8">
                            <Button Style="{StaticResource AccentButton}" Content="{loc:Tr Welcome.Open}"
                                    Command="{Binding OpenRepositoryCommand}" Margin="0,0,8,0"/>
                            <Button Style="{StaticResource ToolButton}" Content="{loc:Tr Repo.Create}"
                                    Command="{Binding CreateRepositoryCommand}" ToolTip="{loc:Tr Repo.Create.Tip}"/>
                            <Button Style="{StaticResource ToolButton}" Content="{loc:Tr Clone.Action}" Margin="8,0,0,0"
                                    Command="{Binding CloneCommand}" ToolTip="{loc:Tr Clone.Tip}"/>
                        </StackPanel>
                        <TextBlock Text="{loc:Tr Welcome.Hint}" Style="{StaticResource MutedText}" TextWrapping="Wrap"
                                   TextAlignment="Center" Margin="0,12" FontSize="12"/>
                    </StackPanel>
                </Grid>
            </Border>

            <GridSplitter Grid.Row="1" Height="6" HorizontalAlignment="Stretch" VerticalAlignment="Center"
                          Background="Transparent"/>

            <!-- ===== Commit details + diff (bottom, horizontal: info+files | diff) ===== -->
            <Border Grid.Row="2" Style="{StaticResource Card}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="320" MinWidth="220"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*" MinWidth="220"/>
                    </Grid.ColumnDefinitions>

                    <!-- left: commit info + changed files -->
                    <Grid Grid.Column="0" DataContext="{Binding Details}"
                          Visibility="{Binding HasCommit, Converter={StaticResource Bool2Vis}, FallbackValue=Collapsed}">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <StackPanel Grid.Row="0" Margin="10,8">
                            <ScrollViewer MaxHeight="130" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                                <TextBlock TextWrapping="Wrap" FontSize="13.5" FontWeight="SemiBold"
                                           beh:Linkify.Text="{Binding MessageFull}" beh:Linkify.RemoteUrl="{Binding RemoteUrl}"/>
                            </ScrollViewer>
                            <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                                <TextBlock Text="{Binding ShortSha}" FontFamily="Consolas" Style="{StaticResource MutedText}"/>
                                <TextBlock Text="  ·  " Style="{StaticResource MutedText}"/>
                                <TextBlock Text="{Binding AuthorName}" Style="{StaticResource MutedText}" TextTrimming="CharacterEllipsis"/>
                            </StackPanel>
                            <TextBlock Text="{Binding DateText}" Style="{StaticResource MutedText}" FontSize="11"/>
                            <WrapPanel Orientation="Horizontal" Margin="0,6,0,0">
                                <Border Background="{DynamicResource Brush.SurfaceAlt}" BorderBrush="{DynamicResource Brush.Border}"
                                        BorderThickness="1" CornerRadius="9" Padding="8,2" Margin="0,0,6,0"
                                        Visibility="{Binding HasSignature, Converter={StaticResource Bool2Vis}}">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="&#xE72E;" FontFamily="Segoe MDL2 Assets" FontSize="10" VerticalAlignment="Center"
                                                   Foreground="{DynamicResource Brush.Success}" Margin="0,0,5,0"/>
                                        <TextBlock Text="{Binding SignatureText}" FontSize="11" VerticalAlignment="Center"
                                                   Foreground="{DynamicResource Brush.Text}"/>
                                    </StackPanel>
                                </Border>
                                <Border Background="{DynamicResource Brush.SurfaceAlt}" BorderBrush="{DynamicResource Brush.Border}"
                                        BorderThickness="1" CornerRadius="9" Padding="8,2"
                                        Visibility="{Binding HasCiStatus, Converter={StaticResource Bool2Vis}}">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="&#xE9F5;" FontFamily="Segoe MDL2 Assets" FontSize="10" VerticalAlignment="Center"
                                                   Foreground="{Binding CiStatusColorKey, Converter={StaticResource Key2Brush}}" Margin="0,0,5,0"/>
                                        <TextBlock Text="{Binding CiStatusText}" FontSize="11" VerticalAlignment="Center"
                                                   Foreground="{DynamicResource Brush.Text}"/>
                                    </StackPanel>
                                </Border>
                            </WrapPanel>
                        </StackPanel>

                        <TextBlock Grid.Row="1" Text="{loc:Tr Details.ChangedFiles}" Style="{StaticResource SectionHeader}"/>
                        <TreeView Grid.Row="2" x:Name="FilesTree" ItemsSource="{Binding FileTree}"
                                  SelectedItemChanged="OnFileTreeSelected" BorderThickness="0" Background="Transparent"
                                  ScrollViewer.VerticalScrollBarVisibility="Auto" ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                            <TreeView.ItemContainerStyle>
                                <Style TargetType="TreeViewItem">
                                    <Setter Property="IsExpanded" Value="{Binding IsExpanded, Mode=TwoWay}"/>
                                    <Setter Property="Foreground" Value="{DynamicResource Brush.Text}"/>
                                </Style>
                            </TreeView.ItemContainerStyle>
                            <TreeView.ItemTemplate>
                                <HierarchicalDataTemplate ItemsSource="{Binding Children}">
                                    <Grid ToolTip="{Binding File.DisplayPath}"
                                          Tag="{Binding DataContext, RelativeSource={RelativeSource AncestorType=Window}}">
                                        <Grid.ContextMenu>
                                            <ContextMenu>
                                                <MenuItem Header="{loc:Tr FileHistory.Menu}"
                                                          Command="{Binding PlacementTarget.Tag.FileHistoryCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                          CommandParameter="{Binding PlacementTarget.DataContext.File, RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                                                <MenuItem Header="{loc:Tr Blame}"
                                                          Command="{Binding PlacementTarget.Tag.BlameCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                          CommandParameter="{Binding PlacementTarget.DataContext.File, RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                                                <Separator/>
                                                <MenuItem Header="{loc:Tr Ctx.RestoreFile}"
                                                          Command="{Binding PlacementTarget.Tag.RestoreFileCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                          CommandParameter="{Binding PlacementTarget.DataContext.File, RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                                            </ContextMenu>
                                        </Grid.ContextMenu>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Width="16" FontWeight="Bold" VerticalAlignment="Center">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Text" Value="{Binding File.StatusLetter}"/>
                                                    <Setter Property="Foreground" Value="{Binding File.StatusColorKey, Converter={StaticResource Key2Brush}}"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsFolder}" Value="True">
                                                            <Setter Property="Text" Value="&#xE8B7;"/>
                                                            <Setter Property="FontFamily" Value="Segoe MDL2 Assets"/>
                                                            <Setter Property="FontSize" Value="10"/>
                                                            <Setter Property="Foreground" Value="{DynamicResource Brush.TextMuted}"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                        <TextBlock Grid.Column="1" Text="{Binding Name}" TextTrimming="CharacterEllipsis"
                                                   Margin="4,0,0,0" VerticalAlignment="Center"/>
                                    </Grid>
                                </HierarchicalDataTemplate>
                            </TreeView.ItemTemplate>
                        </TreeView>
                    </Grid>

                    <GridSplitter Grid.Column="1" Width="6" HorizontalAlignment="Center" VerticalAlignment="Stretch"
                                  Background="Transparent"/>

                    <!-- right: diff (full panel height) -->
                    <Border Grid.Column="2" BorderBrush="{DynamicResource Brush.Border}" BorderThickness="1,0,0,0">
                        <controls:DiffView DataContext="{Binding ActiveDiff}"/>
                    </Border>
                </Grid>
            </Border>
            </Grid>
        </Grid>

        <!-- ================= Status bar ================= -->
        <Border Grid.Row="4" Background="{DynamicResource Brush.Surface}"
                BorderBrush="{DynamicResource Brush.Border}" BorderThickness="0,1,0,0" Padding="10,4">
            <Grid>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="{Binding StatusText}" Style="{StaticResource MutedText}" VerticalAlignment="Center"/>
                    <Button Content="{loc:Tr Common.Cancel}" Style="{StaticResource ToolButton}" Padding="8,1" Margin="10,0,0,0"
                            Command="{Binding CancelNetworkCommand}"
                            Visibility="{Binding CanCancelNetwork, Converter={StaticResource Bool2Vis}}"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <TextBlock Text="{Binding RepositoryPath}" Style="{StaticResource MutedText}" FontSize="11"
                               TextTrimming="CharacterEllipsis" MaxWidth="500" VerticalAlignment="Center"/>
                    <ProgressBar IsIndeterminate="True" Width="90" Height="6" Margin="10,0,0,0"
                                 Visibility="{Binding IsBusy, Converter={StaticResource Bool2Vis}}"/>
                </StackPanel>
            </Grid>
        </Border>
        </Grid>
    </DockPanel>
</Window>
