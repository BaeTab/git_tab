<Window x:Class="GitTab.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:GitTab.App.Controls"
        xmlns:loc="clr-namespace:GitTab.App.Localization"
        Title="{loc:Tr App.Title}"
        Icon="pack://application:,,,/GitTab;component/Assets/gittab.ico"
        Height="760" Width="1220" MinHeight="480" MinWidth="900"
        AllowDrop="True" DragOver="OnDragOver" Drop="OnDrop"
        Background="{DynamicResource Brush.Window}"
        TextOptions.TextFormattingMode="Ideal"
        FontFamily="Segoe UI" FontSize="13">

    <Window.InputBindings>
        <KeyBinding Key="F5" Command="{Binding RefreshCommand}"/>
        <KeyBinding Modifiers="Control" Key="R" Command="{Binding RefreshCommand}"/>
        <KeyBinding Modifiers="Control" Key="O" Command="{Binding OpenRepositoryCommand}"/>
        <KeyBinding Modifiers="Control" Key="Return" Command="{Binding WorkingCopy.CommitCommand}"/>
    </Window.InputBindings>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ================= Toolbar ================= -->
        <Border Grid.Row="0" Background="{DynamicResource Brush.Surface}"
                BorderBrush="{DynamicResource Brush.Border}" BorderThickness="0,0,0,1" Padding="8,6">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- open / recent / refresh -->
                <StackPanel Grid.Column="0" Orientation="Horizontal">
                    <Button Style="{StaticResource AccentButton}" Command="{Binding OpenRepositoryCommand}"
                            Content="{loc:Tr Action.Open}" ToolTip="{loc:Tr Action.Open.Tip}"/>
                    <Menu Background="Transparent" VerticalAlignment="Center" Margin="2,0">
                        <MenuItem Header="{loc:Tr Action.Recent}" ItemsSource="{Binding RecentRepositories}">
                            <MenuItem.ItemContainerStyle>
                                <Style TargetType="MenuItem">
                                    <Setter Property="Header" Value="{Binding Name}"/>
                                    <Setter Property="ToolTip" Value="{Binding Path}"/>
                                    <Setter Property="Command"
                                            Value="{Binding DataContext.OpenRecentCommand, RelativeSource={RelativeSource AncestorType=Window}}"/>
                                    <Setter Property="CommandParameter" Value="{Binding}"/>
                                </Style>
                            </MenuItem.ItemContainerStyle>
                        </MenuItem>
                    </Menu>
                    <Button Style="{StaticResource ToolButton}" Command="{Binding RefreshCommand}"
                            Content="&#xE72C;" FontFamily="Segoe MDL2 Assets" FontSize="13" ToolTip="{loc:Tr Action.Refresh.Tip}"/>
                    <Button Style="{StaticResource ToolButton}" Command="{Binding GenerateGitignoreCommand}"
                            Content="{loc:Tr Gitignore.Button}" ToolTip="{loc:Tr Gitignore.Tip}"
                            Visibility="{Binding IsRepositoryOpen, Converter={StaticResource Bool2Vis}}"/>
                    <Button Style="{StaticResource ToolButton}" Command="{Binding SubmoduleUpdateCommand}"
                            Content="{loc:Tr Submodule.Update}" ToolTip="{loc:Tr Submodule.Update.Tip}"
                            Visibility="{Binding HasSubmodules, Converter={StaticResource Bool2Vis}}"/>
                </StackPanel>

                <!-- remote actions -->
                <StackPanel Grid.Column="1" Orientation="Horizontal" Margin="12,0"
                            Visibility="{Binding IsRepositoryOpen, Converter={StaticResource Bool2Vis}}">
                    <Border Style="{StaticResource Chip}" Background="{DynamicResource Brush.SurfaceAlt}" Padding="8,2">
                        <TextBlock Text="{Binding CurrentBranchName}" FontWeight="SemiBold"/>
                    </Border>
                    <TextBlock VerticalAlignment="Center" Margin="4,0" Style="{StaticResource MutedText}"
                               ToolTip="{loc:Tr Remote.AheadBehind.Tip}">
                        <Run Text="↑"/><Run Text="{Binding Ahead}"/><Run Text="  ↓"/><Run Text="{Binding Behind}"/>
                    </TextBlock>
                    <Button Style="{StaticResource ToolButton}" Command="{Binding FetchCommand}"
                            Content="{loc:Tr Action.Fetch}" ToolTip="{loc:Tr Action.Fetch.Tip}"/>
                    <Button Style="{StaticResource ToolButton}" Command="{Binding PullCommand}"
                            Content="{loc:Tr Action.Pull}" ToolTip="{loc:Tr Action.Pull.Tip}"/>
                    <Button Style="{StaticResource ToolButton}" Command="{Binding PushCommand}"
                            Content="{loc:Tr Action.Push}" ToolTip="{loc:Tr Action.Push.Tip}"/>
                </StackPanel>

                <!-- search -->
                <Grid Grid.Column="2" MaxWidth="360" HorizontalAlignment="Right" Margin="8,0"
                      Visibility="{Binding IsRepositoryOpen, Converter={StaticResource Bool2Vis}}">
                    <TextBox Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged, Delay=150}"
                             ToolTip="{loc:Tr Search.Tip}"/>
                    <TextBlock Text="{loc:Tr Search.Placeholder}" Style="{StaticResource MutedText}"
                               Margin="10,0" VerticalAlignment="Center" IsHitTestVisible="False"
                               Visibility="{Binding SearchText, Converter={StaticResource HasValue2Vis}, ConverterParameter=invert}"/>
                </Grid>

                <!-- language / theme / update -->
                <StackPanel Grid.Column="3" Orientation="Horizontal">
                    <Button Style="{StaticResource ToolButton}" Command="{Binding ToggleLanguageCommand}"
                            Content="한 / EN" ToolTip="{loc:Tr Language}"/>
                    <Button Style="{StaticResource ToolButton}" Command="{Binding ToggleThemeCommand}"
                            Content="&#xE706;" FontFamily="Segoe MDL2 Assets" FontSize="13" ToolTip="{loc:Tr Theme.Toggle}"/>
                    <Button Style="{StaticResource ToolButton}" Command="{Binding CheckUpdatesCommand}"
                            Content="&#xE896;" FontFamily="Segoe MDL2 Assets" FontSize="13" ToolTip="{loc:Tr Update.Checking}"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ================= Conflict / in-progress operation banner ================= -->
        <Border Grid.Row="1" Background="{DynamicResource Brush.SurfaceAlt}"
                BorderBrush="{DynamicResource Brush.Danger}" BorderThickness="0,0,0,2" Padding="14,9"
                Visibility="{Binding IsOperationInProgress, Converter={StaticResource Bool2Vis}}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                    <TextBlock Text="{Binding OperationName}" FontWeight="Bold" Foreground="{DynamicResource Brush.Danger}"/>
                    <TextBlock Text="{loc:Tr Conflict.Hint}" Style="{StaticResource MutedText}" TextWrapping="Wrap"/>
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Content="{loc:Tr Conflict.Continue}" Style="{StaticResource AccentButton}" Margin="0,0,8,0"
                            Command="{Binding ContinueOperationCommand}"/>
                    <Button Content="{loc:Tr Conflict.Abort}" Command="{Binding AbortOperationCommand}"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ================= Main content ================= -->
        <Grid Grid.Row="2" Margin="8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="280" MinWidth="220"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*" MinWidth="340"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="440" MinWidth="300"/>
            </Grid.ColumnDefinitions>

            <!-- ===== Left: Changes / Branches ===== -->
            <Border Grid.Column="0" Style="{StaticResource Card}">
                <TabControl Background="Transparent" BorderThickness="0">
                    <!-- Changes / staging -->
                    <TabItem Header="{loc:Tr Panel.Changes}" DataContext="{Binding WorkingCopy}">
                        <Grid Margin="4">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <!-- unstaged -->
                            <DockPanel Grid.Row="0">
                                <Grid DockPanel.Dock="Top">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="{loc:Tr WC.Unstaged}" Style="{StaticResource SectionHeader}"
                                               TextTrimming="CharacterEllipsis" VerticalAlignment="Center"/>
                                    <Button Grid.Column="1" Content="+" Style="{StaticResource ToolButton}" VerticalAlignment="Center"
                                            Command="{Binding StageAllCommand}" ToolTip="{loc:Tr WC.StageAll.Tip}"/>
                                </Grid>
                                <ListBox ItemsSource="{Binding Unstaged}" SelectedItem="{Binding SelectedFile}">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <Grid ToolTip="{Binding DisplayPath}">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0" Text="{Binding StatusLetter}" Width="16" FontWeight="Bold"
                                                           Foreground="{Binding StatusColorKey, Converter={StaticResource Key2Brush}}"/>
                                                <TextBlock Grid.Column="1" Text="{Binding DisplayPath}" TextTrimming="CharacterEllipsis"/>
                                                <StackPanel Grid.Column="2" Orientation="Horizontal">
                                                    <Button Content="+" Style="{StaticResource ToolButton}" Padding="6,0"
                                                            Command="{Binding DataContext.StageCommand, RelativeSource={RelativeSource AncestorType=ListBox}}"
                                                            CommandParameter="{Binding}" ToolTip="{loc:Tr WC.Stage.Tip}"/>
                                                    <Button Content="" FontFamily="Segoe MDL2 Assets" FontSize="12" Style="{StaticResource ToolButton}" Padding="6,0"
                                                            Command="{Binding DataContext.DiscardCommand, RelativeSource={RelativeSource AncestorType=ListBox}}"
                                                            CommandParameter="{Binding}" ToolTip="{loc:Tr WC.Discard.Tip}"/>
                                                </StackPanel>
                                            </Grid>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                            </DockPanel>

                            <!-- staged -->
                            <DockPanel Grid.Row="1">
                                <Grid DockPanel.Dock="Top">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="{loc:Tr WC.Staged}" Style="{StaticResource SectionHeader}"
                                               TextTrimming="CharacterEllipsis" VerticalAlignment="Center"/>
                                    <Button Grid.Column="1" Content="−" Style="{StaticResource ToolButton}" VerticalAlignment="Center"
                                            Command="{Binding UnstageAllCommand}" ToolTip="{loc:Tr WC.UnstageAll}"/>
                                </Grid>
                                <ListBox ItemsSource="{Binding Staged}" SelectedItem="{Binding SelectedFile}">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <Grid ToolTip="{Binding DisplayPath}">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0" Text="{Binding StatusLetter}" Width="16" FontWeight="Bold"
                                                           Foreground="{Binding StatusColorKey, Converter={StaticResource Key2Brush}}"/>
                                                <TextBlock Grid.Column="1" Text="{Binding DisplayPath}" TextTrimming="CharacterEllipsis"/>
                                                <Button Grid.Column="2" Content="−" Style="{StaticResource ToolButton}" Padding="6,0"
                                                        Command="{Binding DataContext.UnstageCommand, RelativeSource={RelativeSource AncestorType=ListBox}}"
                                                        CommandParameter="{Binding}" ToolTip="{loc:Tr WC.Unstage.Tip}"/>
                                            </Grid>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                            </DockPanel>

                            <!-- commit box -->
                            <StackPanel Grid.Row="2" Margin="6,6">
                                <TextBox Text="{Binding CommitMessage, UpdateSourceTrigger=PropertyChanged}"
                                         AcceptsReturn="True" TextWrapping="Wrap" MinHeight="54" MaxHeight="120"
                                         VerticalScrollBarVisibility="Auto"
                                         ToolTip="{loc:Tr WC.Commit.Tip}"/>
                                <CheckBox Content="{loc:Tr WC.Amend}" IsChecked="{Binding Amend}" Margin="0,8,0,0"
                                          Foreground="{DynamicResource Brush.Text}" ToolTip="{loc:Tr WC.Amend.Tip}"/>
                                <Button HorizontalAlignment="Stretch" Style="{StaticResource AccentButton}" Margin="0,8,0,0"
                                        Content="{loc:Tr WC.Commit}" Command="{Binding CommitCommand}"
                                        ToolTip="{loc:Tr WC.Commit.Tip}"/>
                                <TextBlock Text="{loc:Tr WC.Clean}" Style="{StaticResource MutedText}" Margin="2,6,0,0"
                                           TextWrapping="Wrap"
                                           Visibility="{Binding IsClean, Converter={StaticResource Bool2Vis}}"/>
                            </StackPanel>
                        </Grid>
                    </TabItem>

                    <!-- Branches -->
                    <TabItem Header="{loc:Tr Panel.Branches}" DataContext="{Binding Branches}">
                        <ScrollViewer VerticalScrollBarVisibility="Auto" Margin="2">
                            <StackPanel>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="{loc:Tr Branch.Local}" Style="{StaticResource SectionHeader}"
                                               TextTrimming="CharacterEllipsis" VerticalAlignment="Center"/>
                                    <Button Grid.Column="1" Content="+" Style="{StaticResource ToolButton}" VerticalAlignment="Center"
                                            Command="{Binding NewBranchCommand}" ToolTip="{loc:Tr Branch.New.Tip}"/>
                                </Grid>
                                <ListBox ItemsSource="{Binding Local}" SelectedItem="{Binding SelectedBranch}">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <Grid Tag="{Binding DataContext, RelativeSource={RelativeSource AncestorType=ListBox}}">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <Grid.ContextMenu>
                                                    <ContextMenu>
                                                        <MenuItem Header="{loc:Tr Branch.Checkout}"
                                                                  Command="{Binding PlacementTarget.Tag.CheckoutCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                                  CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                                                        <MenuItem Header="{loc:Tr Branch.Merge}"
                                                                  Command="{Binding PlacementTarget.Tag.MergeCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                                  CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                                                        <MenuItem Header="{loc:Tr Branch.Rebase}"
                                                                  Command="{Binding PlacementTarget.Tag.RebaseCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                                  CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                                                        <Separator/>
                                                        <MenuItem Header="{loc:Tr Branch.Rename}"
                                                                  Command="{Binding PlacementTarget.Tag.RenameCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                                  CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                                                        <MenuItem Header="{loc:Tr Branch.Delete}"
                                                                  Command="{Binding PlacementTarget.Tag.DeleteCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                                  CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                                                    </ContextMenu>
                                                </Grid.ContextMenu>
                                                <TextBlock Grid.Column="0" Text="{Binding FriendlyName}" TextTrimming="CharacterEllipsis">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock" BasedOn="{StaticResource {x:Type TextBlock}}">
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsCurrent}" Value="True">
                                                                    <Setter Property="FontWeight" Value="Bold"/>
                                                                    <Setter Property="Foreground" Value="{DynamicResource Brush.Accent}"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                                <TextBlock Grid.Column="1" Text="{Binding AheadBehindText}" Style="{StaticResource MutedText}" FontSize="11"/>
                                            </Grid>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>

                                <TextBlock Text="{loc:Tr Branch.Remote}" Style="{StaticResource SectionHeader}"/>
                                <ListBox ItemsSource="{Binding Remote}" SelectedItem="{Binding SelectedBranch}">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <Grid Tag="{Binding DataContext, RelativeSource={RelativeSource AncestorType=ListBox}}">
                                                <Grid.ContextMenu>
                                                    <ContextMenu>
                                                        <MenuItem Header="{loc:Tr Branch.Checkout}"
                                                                  Command="{Binding PlacementTarget.Tag.CheckoutCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                                  CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                                                        <MenuItem Header="{loc:Tr Branch.Merge}"
                                                                  Command="{Binding PlacementTarget.Tag.MergeCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                                  CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                                                        <Separator/>
                                                        <MenuItem Header="{loc:Tr Ctx.DeleteRemote}"
                                                                  Command="{Binding PlacementTarget.Tag.DeleteRemoteCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                                  CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                                                    </ContextMenu>
                                                </Grid.ContextMenu>
                                                <TextBlock Text="{Binding FriendlyName}" TextTrimming="CharacterEllipsis"
                                                           Style="{StaticResource MutedText}"/>
                                            </Grid>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>

                                <!-- Tags -->
                                <TextBlock Text="{loc:Tr Tag.Section}" Style="{StaticResource SectionHeader}"/>
                                <ListBox ItemsSource="{Binding Tags}">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <Grid Tag="{Binding DataContext, RelativeSource={RelativeSource AncestorType=ListBox}}">
                                                <Grid.ContextMenu>
                                                    <ContextMenu>
                                                        <MenuItem Header="{loc:Tr Tag.Push}"
                                                                  Command="{Binding PlacementTarget.Tag.PushTagCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                                  CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                                                        <MenuItem Header="{loc:Tr Tag.Delete}"
                                                                  Command="{Binding PlacementTarget.Tag.DeleteTagCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                                  CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                                                    </ContextMenu>
                                                </Grid.ContextMenu>
                                                <TextBlock Text="{Binding Name}" TextTrimming="CharacterEllipsis"/>
                                            </Grid>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>

                                <!-- Stashes (owned by MainViewModel) -->
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="{loc:Tr Stash.Section}" Style="{StaticResource SectionHeader}"
                                               VerticalAlignment="Center"/>
                                    <Button Grid.Column="1" Content="+" Style="{StaticResource ToolButton}" VerticalAlignment="Center"
                                            Command="{Binding DataContext.StashPushCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                            ToolTip="{loc:Tr Stash.Push.Tip}"/>
                                </Grid>
                                <ListBox ItemsSource="{Binding DataContext.Stashes, RelativeSource={RelativeSource AncestorType=Window}}">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <Grid Tag="{Binding DataContext, RelativeSource={RelativeSource AncestorType=Window}}"
                                                  ToolTip="{Binding Message}">
                                                <Grid.ContextMenu>
                                                    <ContextMenu>
                                                        <MenuItem Header="{loc:Tr Stash.Pop}"
                                                                  Command="{Binding PlacementTarget.Tag.StashPopCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                                  CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                                                        <MenuItem Header="{loc:Tr Stash.Apply}"
                                                                  Command="{Binding PlacementTarget.Tag.StashApplyCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                                  CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                                                        <MenuItem Header="{loc:Tr Stash.Drop}"
                                                                  Command="{Binding PlacementTarget.Tag.StashDropCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                                  CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                                                    </ContextMenu>
                                                </Grid.ContextMenu>
                                                <TextBlock Text="{Binding Message}" TextTrimming="CharacterEllipsis"/>
                                            </Grid>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                            </StackPanel>
                        </ScrollViewer>
                    </TabItem>
                </TabControl>
            </Border>

            <GridSplitter Grid.Column="1" Width="6" HorizontalAlignment="Center" Background="Transparent"
                          VerticalAlignment="Stretch"/>

            <!-- ===== Center: history graph ===== -->
            <Border Grid.Column="2" Style="{StaticResource Card}" ClipToBounds="True">
                <Grid>
                    <ScrollViewer CanContentScroll="True" VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled"
                                  Visibility="{Binding IsRepositoryOpen, Converter={StaticResource Bool2Vis}}">
                        <controls:CommitGraphControl
                            Rows="{Binding Rows}"
                            LaneCount="{Binding LaneCount}"
                            SelectedIndex="{Binding SelectedCommitIndex, Mode=TwoWay}">
                            <controls:CommitGraphControl.ContextMenu>
                                <ContextMenu DataContext="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource Self}}">
                                    <MenuItem Header="{loc:Tr Ctx.CheckoutCommit}" Command="{Binding CheckoutCommitCommand}"/>
                                    <MenuItem Header="{loc:Tr Ctx.CreateBranch}" Command="{Binding CreateBranchHereCommand}"/>
                                    <MenuItem Header="{loc:Tr Ctx.CreateTag}" Command="{Binding CreateTagHereCommand}"/>
                                    <Separator/>
                                    <MenuItem Header="{loc:Tr Ctx.Revert}" Command="{Binding RevertCommitCommand}"/>
                                    <MenuItem Header="{loc:Tr Ctx.CherryPick}" Command="{Binding CherryPickCommand}"/>
                                    <MenuItem Header="{loc:Tr Ctx.InteractiveRebase}" Command="{Binding InteractiveRebaseCommand}"/>
                                    <Separator/>
                                    <MenuItem Header="{loc:Tr Ctx.ResetSoft}" Command="{Binding ResetSoftCommand}"/>
                                    <MenuItem Header="{loc:Tr Ctx.ResetMixed}" Command="{Binding ResetMixedCommand}"/>
                                    <MenuItem Header="{loc:Tr Ctx.ResetHard}" Command="{Binding ResetHardCommand}"/>
                                    <Separator/>
                                    <MenuItem Header="{loc:Tr Ctx.CopySha}" Command="{Binding CopyShaCommand}"/>
                                    <MenuItem Header="{loc:Tr Ctx.CopyMessage}" Command="{Binding CopyMessageCommand}"/>
                                </ContextMenu>
                            </controls:CommitGraphControl.ContextMenu>
                        </controls:CommitGraphControl>
                    </ScrollViewer>

                    <!-- welcome / empty state -->
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" MaxWidth="420"
                                Visibility="{Binding IsRepositoryOpen, Converter={StaticResource Bool2Vis}, ConverterParameter=invert}">
                        <TextBlock Text="{loc:Tr Welcome.Title}" FontSize="22" FontWeight="Bold" HorizontalAlignment="Center"/>
                        <TextBlock Text="{loc:Tr Welcome.Subtitle}" Style="{StaticResource MutedText}" TextWrapping="Wrap"
                                   TextAlignment="Center" Margin="0,8"/>
                        <Button Style="{StaticResource AccentButton}" Content="{loc:Tr Welcome.Open}"
                                Command="{Binding OpenRepositoryCommand}" HorizontalAlignment="Center" Margin="0,8"/>
                        <TextBlock Text="{loc:Tr Welcome.Hint}" Style="{StaticResource MutedText}" TextWrapping="Wrap"
                                   TextAlignment="Center" Margin="0,12" FontSize="12"/>
                    </StackPanel>
                </Grid>
            </Border>

            <GridSplitter Grid.Column="3" Width="6" HorizontalAlignment="Center" Background="Transparent"
                          VerticalAlignment="Stretch"/>

            <!-- ===== Right: details + diff ===== -->
            <Border Grid.Column="4" Style="{StaticResource Card}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- commit details header -->
                    <StackPanel Grid.Row="0" Margin="10,8" DataContext="{Binding Details}"
                                Visibility="{Binding HasCommit, Converter={StaticResource Bool2Vis}}">
                        <TextBlock Text="{Binding MessageFull}" TextWrapping="Wrap" FontSize="14" MaxHeight="120"
                                   FontWeight="SemiBold"/>
                        <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                            <TextBlock Text="{Binding ShortSha}" FontFamily="Consolas" Style="{StaticResource MutedText}"/>
                            <TextBlock Text="  ·  " Style="{StaticResource MutedText}"/>
                            <TextBlock Text="{Binding AuthorName}" Style="{StaticResource MutedText}" TextTrimming="CharacterEllipsis"/>
                        </StackPanel>
                        <TextBlock Text="{Binding DateText}" Style="{StaticResource MutedText}" FontSize="11"/>
                    </StackPanel>

                    <!-- changed files of the selected commit -->
                    <DockPanel Grid.Row="1" DataContext="{Binding Details}"
                               Visibility="{Binding HasCommit, Converter={StaticResource Bool2Vis}}" MaxHeight="180">
                        <TextBlock DockPanel.Dock="Top" Text="{loc:Tr Details.ChangedFiles}" Style="{StaticResource SectionHeader}"/>
                        <ListBox ItemsSource="{Binding Files}" SelectedItem="{Binding SelectedFile}"
                                 MaxHeight="150" ScrollViewer.VerticalScrollBarVisibility="Auto">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Grid ToolTip="{Binding DisplayPath}"
                                          Tag="{Binding DataContext, RelativeSource={RelativeSource AncestorType=Window}}">
                                        <Grid.ContextMenu>
                                            <ContextMenu>
                                                <MenuItem Header="{loc:Tr Blame}"
                                                          Command="{Binding PlacementTarget.Tag.BlameCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                          CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                                            </ContextMenu>
                                        </Grid.ContextMenu>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="{Binding StatusLetter}" Width="16" FontWeight="Bold"
                                                   Foreground="{Binding StatusColorKey, Converter={StaticResource Key2Brush}}"/>
                                        <TextBlock Grid.Column="1" Text="{Binding DisplayPath}" TextTrimming="CharacterEllipsis"/>
                                    </Grid>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </DockPanel>

                    <!-- diff -->
                    <Border Grid.Row="2" BorderBrush="{DynamicResource Brush.Border}" BorderThickness="0,1,0,0">
                        <controls:DiffView DataContext="{Binding ActiveDiff}"/>
                    </Border>
                </Grid>
            </Border>
        </Grid>

        <!-- ================= Status bar ================= -->
        <Border Grid.Row="3" Background="{DynamicResource Brush.Surface}"
                BorderBrush="{DynamicResource Brush.Border}" BorderThickness="0,1,0,0" Padding="10,4">
            <Grid>
                <TextBlock Text="{Binding StatusText}" Style="{StaticResource MutedText}" VerticalAlignment="Center"/>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <TextBlock Text="{Binding RepositoryPath}" Style="{StaticResource MutedText}" FontSize="11"
                               TextTrimming="CharacterEllipsis" MaxWidth="500" VerticalAlignment="Center"/>
                    <ProgressBar IsIndeterminate="True" Width="90" Height="6" Margin="10,0,0,0"
                                 Visibility="{Binding IsBusy, Converter={StaticResource Bool2Vis}}"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
