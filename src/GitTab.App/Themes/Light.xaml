<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Light theme — clean neutral + indigo -->
    <SolidColorBrush x:Key="Brush.Window"     Color="#F4F5F7"/>
    <SolidColorBrush x:Key="Brush.Surface"    Color="#FFFFFF"/>
    <SolidColorBrush x:Key="Brush.SurfaceAlt" Color="#EEF0F3"/>
    <SolidColorBrush x:Key="Brush.Border"     Color="#E0E3E9"/>
    <SolidColorBrush x:Key="Brush.Text"       Color="#1C2128"/>
    <SolidColorBrush x:Key="Brush.TextMuted"  Color="#656D76"/>
    <SolidColorBrush x:Key="Brush.Accent"     Color="#5560D9"/>
    <SolidColorBrush x:Key="Brush.OnAccent"   Color="#FFFFFF"/>
    <SolidColorBrush x:Key="Brush.Selection"  Color="#E8EBFB"/>
    <SolidColorBrush x:Key="Brush.Hover"      Color="#EEF0F4"/>
    <SolidColorBrush x:Key="Brush.Danger"     Color="#D0384B"/>
    <SolidColorBrush x:Key="Brush.Success"    Color="#1F8A54"/>

    <SolidColorBrush x:Key="Diff.AddBg"   Color="#E8FBEE"/>
    <SolidColorBrush x:Key="Diff.DelBg"   Color="#FDEBEC"/>
    <!-- Moved code (git color-moved): blue for the new location, violet for the old. -->
    <SolidColorBrush x:Key="Diff.MovedAddBg" Color="#E3ECFB"/>
    <SolidColorBrush x:Key="Diff.MovedDelBg" Color="#EDE7FB"/>
    <SolidColorBrush x:Key="Diff.AddWordBg" Color="#A6E7BC"/>
    <SolidColorBrush x:Key="Diff.DelWordBg" Color="#F6B2B8"/>
    <SolidColorBrush x:Key="Diff.HunkBg"  Color="#ECEEFB"/>
    <SolidColorBrush x:Key="Diff.AddText" Color="#106B2E"/>
    <SolidColorBrush x:Key="Diff.DelText" Color="#A31F2C"/>
    <SolidColorBrush x:Key="Diff.Gutter"  Color="#656D76"/>

    <SolidColorBrush x:Key="Chip.Head.Bg"   Color="#5560D9"/>
    <SolidColorBrush x:Key="Chip.Head.Text" Color="#FFFFFF"/>
    <SolidColorBrush x:Key="Chip.Local.Bg"   Color="#E7EAFC"/>
    <SolidColorBrush x:Key="Chip.Local.Text" Color="#2C3AA8"/>
    <SolidColorBrush x:Key="Chip.Remote.Bg"   Color="#EFE9FB"/>
    <SolidColorBrush x:Key="Chip.Remote.Text" Color="#5B3E9E"/>
    <SolidColorBrush x:Key="Chip.Tag.Bg"   Color="#FBF3D6"/>
    <SolidColorBrush x:Key="Chip.Tag.Text" Color="#7A5B00"/>

</ResourceDictionary>
