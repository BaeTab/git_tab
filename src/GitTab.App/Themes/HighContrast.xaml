<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- High-contrast theme — pure black surfaces, white text, vivid cyan accent, strong borders.
         Aimed at low-vision / accessibility use (WCAG-friendly contrast ratios). -->
    <SolidColorBrush x:Key="Brush.Window"     Color="#000000"/>
    <SolidColorBrush x:Key="Brush.Surface"    Color="#000000"/>
    <SolidColorBrush x:Key="Brush.SurfaceAlt" Color="#0C0C0C"/>
    <SolidColorBrush x:Key="Brush.Border"     Color="#B4B4B4"/>
    <SolidColorBrush x:Key="Brush.Text"       Color="#FFFFFF"/>
    <SolidColorBrush x:Key="Brush.TextMuted"  Color="#D6D6D6"/>
    <SolidColorBrush x:Key="Brush.Accent"     Color="#35E0FF"/>
    <SolidColorBrush x:Key="Brush.OnAccent"   Color="#000000"/>
    <SolidColorBrush x:Key="Brush.Selection"  Color="#0A3A66"/>
    <SolidColorBrush x:Key="Brush.Hover"      Color="#1A1A1A"/>
    <SolidColorBrush x:Key="Brush.Danger"     Color="#FF6B6B"/>
    <SolidColorBrush x:Key="Brush.Success"    Color="#5BFF9E"/>

    <SolidColorBrush x:Key="Diff.AddBg"   Color="#00330F"/>
    <SolidColorBrush x:Key="Diff.DelBg"   Color="#3A0000"/>
    <!-- Moved code (git color-moved): blue for the new location, violet for the old. -->
    <SolidColorBrush x:Key="Diff.MovedAddBg" Color="#002A4D"/>
    <SolidColorBrush x:Key="Diff.MovedDelBg" Color="#2A0A4D"/>
    <SolidColorBrush x:Key="Diff.AddWordBg" Color="#008A3A"/>
    <SolidColorBrush x:Key="Diff.DelWordBg" Color="#9E0000"/>
    <SolidColorBrush x:Key="Diff.HunkBg"  Color="#0A0A33"/>
    <SolidColorBrush x:Key="Diff.AddText" Color="#5BFF9E"/>
    <SolidColorBrush x:Key="Diff.DelText" Color="#FF8A8A"/>
    <SolidColorBrush x:Key="Diff.Gutter"  Color="#D6D6D6"/>

    <SolidColorBrush x:Key="Chip.Head.Bg"   Color="#35E0FF"/>
    <SolidColorBrush x:Key="Chip.Head.Text" Color="#000000"/>
    <SolidColorBrush x:Key="Chip.Local.Bg"   Color="#0A3A66"/>
    <SolidColorBrush x:Key="Chip.Local.Text" Color="#B7ECFF"/>
    <SolidColorBrush x:Key="Chip.Remote.Bg"   Color="#3A0A55"/>
    <SolidColorBrush x:Key="Chip.Remote.Text" Color="#E3C3FF"/>
    <SolidColorBrush x:Key="Chip.Tag.Bg"   Color="#4D4300"/>
    <SolidColorBrush x:Key="Chip.Tag.Text" Color="#FFE873"/>

</ResourceDictionary>
