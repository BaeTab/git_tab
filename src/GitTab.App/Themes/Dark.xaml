<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Dark theme — refined slate + indigo (ties to the app mark) -->
    <SolidColorBrush x:Key="Brush.Window"     Color="#15171C"/>
    <SolidColorBrush x:Key="Brush.Surface"    Color="#1B1E24"/>
    <SolidColorBrush x:Key="Brush.SurfaceAlt" Color="#222630"/>
    <SolidColorBrush x:Key="Brush.Border"     Color="#2B303A"/>
    <SolidColorBrush x:Key="Brush.Text"       Color="#D6DAE1"/>
    <SolidColorBrush x:Key="Brush.TextMuted"  Color="#79818E"/>
    <SolidColorBrush x:Key="Brush.Accent"     Color="#6B78E8"/>
    <SolidColorBrush x:Key="Brush.OnAccent"   Color="#FFFFFF"/>
    <SolidColorBrush x:Key="Brush.Selection"  Color="#262C40"/>
    <SolidColorBrush x:Key="Brush.Hover"      Color="#232732"/>
    <SolidColorBrush x:Key="Brush.Danger"     Color="#E56B7B"/>
    <SolidColorBrush x:Key="Brush.Success"    Color="#4FBF8B"/>

    <SolidColorBrush x:Key="Diff.AddBg"   Color="#14271D"/>
    <SolidColorBrush x:Key="Diff.DelBg"   Color="#2A181B"/>
    <SolidColorBrush x:Key="Diff.AddWordBg" Color="#2C6B43"/>
    <SolidColorBrush x:Key="Diff.DelWordBg" Color="#6E2A34"/>
    <SolidColorBrush x:Key="Diff.HunkBg"  Color="#1D2233"/>
    <SolidColorBrush x:Key="Diff.AddText" Color="#6BD08B"/>
    <SolidColorBrush x:Key="Diff.DelText" Color="#F08A93"/>
    <SolidColorBrush x:Key="Diff.Gutter"  Color="#79818E"/>

    <SolidColorBrush x:Key="Chip.Head.Bg"   Color="#6B78E8"/>
    <SolidColorBrush x:Key="Chip.Head.Text" Color="#FFFFFF"/>
    <SolidColorBrush x:Key="Chip.Local.Bg"   Color="#232A3D"/>
    <SolidColorBrush x:Key="Chip.Local.Text" Color="#A9B4F1"/>
    <SolidColorBrush x:Key="Chip.Remote.Bg"   Color="#2C2740"/>
    <SolidColorBrush x:Key="Chip.Remote.Text" Color="#C3B2EE"/>
    <SolidColorBrush x:Key="Chip.Tag.Bg"   Color="#33301F"/>
    <SolidColorBrush x:Key="Chip.Tag.Text" Color="#DCC873"/>

</ResourceDictionary>
