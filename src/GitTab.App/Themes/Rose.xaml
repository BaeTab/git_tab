<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Rose theme — Rosé Pine, soft dark palette with iris/foam/gold/love accents -->
    <SolidColorBrush x:Key="Brush.Window"     Color="#191724"/>
    <SolidColorBrush x:Key="Brush.Surface"    Color="#1F1D2E"/>
    <SolidColorBrush x:Key="Brush.SurfaceAlt" Color="#26233A"/>
    <SolidColorBrush x:Key="Brush.Border"     Color="#403D52"/>
    <SolidColorBrush x:Key="Brush.Text"       Color="#E0DEF4"/>
    <SolidColorBrush x:Key="Brush.TextMuted"  Color="#6E6A86"/>
    <SolidColorBrush x:Key="Brush.Accent"     Color="#C4A7E7"/>
    <SolidColorBrush x:Key="Brush.OnAccent"   Color="#191724"/>
    <SolidColorBrush x:Key="Brush.Selection"  Color="#302B4A"/>
    <SolidColorBrush x:Key="Brush.Hover"      Color="#2A2740"/>
    <SolidColorBrush x:Key="Brush.Danger"     Color="#EB6F92"/>
    <SolidColorBrush x:Key="Brush.Success"    Color="#9CCFD8"/>

    <SolidColorBrush x:Key="Diff.AddBg"   Color="#16272A"/>
    <SolidColorBrush x:Key="Diff.DelBg"   Color="#2C1C24"/>
    <!-- Moved code (git color-moved): blue for the new location, violet for the old, so it reads
         differently from a genuine add (green) / remove (red). -->
    <SolidColorBrush x:Key="Diff.MovedAddBg" Color="#16283A"/>
    <SolidColorBrush x:Key="Diff.MovedDelBg" Color="#291F3D"/>
    <SolidColorBrush x:Key="Diff.AddWordBg" Color="#2C5C61"/>
    <SolidColorBrush x:Key="Diff.DelWordBg" Color="#6E2E42"/>
    <SolidColorBrush x:Key="Diff.HunkBg"  Color="#1E2438"/>
    <SolidColorBrush x:Key="Diff.AddText" Color="#ACE0E6"/>
    <SolidColorBrush x:Key="Diff.DelText" Color="#F5A0B4"/>
    <SolidColorBrush x:Key="Diff.Gutter"  Color="#6E6A86"/>

    <SolidColorBrush x:Key="Chip.Head.Bg"   Color="#C4A7E7"/>
    <SolidColorBrush x:Key="Chip.Head.Text" Color="#191724"/>
    <SolidColorBrush x:Key="Chip.Local.Bg"   Color="#17293A"/>
    <SolidColorBrush x:Key="Chip.Local.Text" Color="#9CCFD8"/>
    <SolidColorBrush x:Key="Chip.Remote.Bg"   Color="#2A2340"/>
    <SolidColorBrush x:Key="Chip.Remote.Text" Color="#D3BFF0"/>
    <SolidColorBrush x:Key="Chip.Tag.Bg"   Color="#362B18"/>
    <SolidColorBrush x:Key="Chip.Tag.Text" Color="#F6C177"/>

</ResourceDictionary>
