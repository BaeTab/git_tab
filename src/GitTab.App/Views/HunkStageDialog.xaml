<Window x:Class="GitTab.App.Views.HunkStageDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:loc="clr-namespace:GitTab.App.Localization"
        Title="{loc:Tr WC.StagePartial}"
        Icon="pack://application:,,,/GitTab;component/Assets/gittab.ico"
        Width="720" Height="560" MinWidth="520" MinHeight="360"
        WindowStartupLocation="CenterOwner" ShowInTaskbar="False"
        Background="{DynamicResource Brush.Window}"
        FontFamily="Segoe UI" FontSize="13">
    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,10">
            <TextBlock Text="{loc:Tr WC.StagePartial}" FontSize="18" FontWeight="SemiBold" Foreground="{DynamicResource Brush.Text}"/>
            <TextBlock Text="{Binding FilePath}" Style="{StaticResource MutedText}" TextTrimming="CharacterEllipsis"/>
            <TextBlock Text="{loc:Tr WC.StagePartial.Tip}" Style="{StaticResource MutedText}" TextWrapping="Wrap" Margin="0,2,0,0"/>
        </StackPanel>

        <Grid Grid.Row="1">
            <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto">
                <ItemsControl ItemsSource="{Binding Hunks}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Background="{DynamicResource Brush.SurfaceAlt}" BorderBrush="{DynamicResource Brush.Border}"
                                    BorderThickness="1" CornerRadius="6" Margin="0,0,0,10">
                                <Grid Margin="10">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <Grid Grid.Row="0" Margin="0,0,0,6">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="{Binding HunkHeader}" FontFamily="Consolas"
                                                   Foreground="{DynamicResource Brush.TextMuted}" TextTrimming="CharacterEllipsis" VerticalAlignment="Center"/>
                                        <StackPanel Grid.Column="1" Orientation="Horizontal">
                                            <Button Content="{loc:Tr HunkStage.StageLines}" Padding="10,3" Margin="0,0,6,0"
                                                    Command="{Binding DataContext.StageLinesCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                    CommandParameter="{Binding}"/>
                                            <Button Content="{loc:Tr WC.StagePartial.StageHunk}" Style="{StaticResource AccentButton}" Padding="10,3"
                                                    Command="{Binding DataContext.StageCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                    CommandParameter="{Binding}"/>
                                        </StackPanel>
                                    </Grid>
                                    <ItemsControl Grid.Row="1" ItemsSource="{Binding Lines}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="20"/>
                                                        <ColumnDefinition Width="*"/>
                                                    </Grid.ColumnDefinitions>
                                                    <CheckBox Grid.Column="0" IsChecked="{Binding IsSelected}" VerticalAlignment="Center"
                                                              Visibility="{Binding IsChange, Converter={StaticResource Bool2Vis}}"/>
                                                    <TextBlock Grid.Column="1" Text="{Binding Text}" FontFamily="Consolas" FontSize="12"
                                                               Foreground="{DynamicResource Brush.Text}" TextWrapping="NoWrap"/>
                                                </Grid>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>

            <TextBlock Text="{loc:Tr WC.StagePartial.Empty}" Style="{StaticResource MutedText}"
                       HorizontalAlignment="Center" VerticalAlignment="Center"
                       Visibility="{Binding IsEmpty, Converter={StaticResource Bool2Vis}}"/>
        </Grid>

        <Button Grid.Row="2" Content="{loc:Tr Common.Close}" IsCancel="True" IsDefault="True"
                HorizontalAlignment="Right" MinWidth="88" Margin="0,12,0,0"/>
    </Grid>
</Window>
