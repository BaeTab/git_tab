<Window x:Class="GitTab.App.Views.ConflictResolverDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:loc="clr-namespace:GitTab.App.Localization"
        Title="{loc:Tr Conflict.Resolve}"
        Width="880" Height="640" MinWidth="620" MinHeight="420"
        WindowStartupLocation="CenterOwner" ShowInTaskbar="False"
        Background="{DynamicResource Brush.Window}" FontFamily="Segoe UI" FontSize="13">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,8">
            <TextBlock Text="{Binding DisplayPath}" FontWeight="SemiBold" FontFamily="Consolas"/>
            <TextBlock Text="{loc:Tr Conflict.ResolveHint}" Style="{StaticResource MutedText}" TextWrapping="Wrap" Margin="0,4,0,0"/>
        </StackPanel>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <ItemsControl ItemsSource="{Binding Blocks}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Style="{StaticResource Card}" Padding="10" Margin="0,0,0,10">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                    <TextBlock Text="#" Style="{StaticResource MutedText}"/>
                                    <TextBlock Text="{Binding Index}" Style="{StaticResource MutedText}" Margin="0,0,12,0"/>
                                    <RadioButton Content="{loc:Tr Conflict.UseOurs}" Margin="0,0,12,0" Foreground="{DynamicResource Brush.Text}"
                                                 IsChecked="{Binding Choice, Converter={StaticResource EnumBool}, ConverterParameter=Ours}"/>
                                    <RadioButton Content="{loc:Tr Conflict.UseTheirs}" Margin="0,0,12,0" Foreground="{DynamicResource Brush.Text}"
                                                 IsChecked="{Binding Choice, Converter={StaticResource EnumBool}, ConverterParameter=Theirs}"/>
                                    <RadioButton Content="{loc:Tr Conflict.Both}" Foreground="{DynamicResource Brush.Text}"
                                                 IsChecked="{Binding Choice, Converter={StaticResource EnumBool}, ConverterParameter=Both}"/>
                                </StackPanel>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="8"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Border Grid.Column="0" Background="{DynamicResource Diff.DelBg}" CornerRadius="4" Padding="6">
                                        <StackPanel>
                                            <TextBlock Text="{loc:Tr Conflict.Ours}" Style="{StaticResource MutedText}" FontSize="11"/>
                                            <TextBox Text="{Binding Ours, Mode=OneWay}" IsReadOnly="True" FontFamily="Consolas" FontSize="12"
                                                     Background="Transparent" BorderThickness="0" TextWrapping="NoWrap"
                                                     HorizontalScrollBarVisibility="Auto"/>
                                        </StackPanel>
                                    </Border>
                                    <Border Grid.Column="2" Background="{DynamicResource Diff.AddBg}" CornerRadius="4" Padding="6">
                                        <StackPanel>
                                            <TextBlock Text="{loc:Tr Conflict.Theirs}" Style="{StaticResource MutedText}" FontSize="11"/>
                                            <TextBox Text="{Binding Theirs, Mode=OneWay}" IsReadOnly="True" FontFamily="Consolas" FontSize="12"
                                                     Background="Transparent" BorderThickness="0" TextWrapping="NoWrap"
                                                     HorizontalScrollBarVisibility="Auto"/>
                                        </StackPanel>
                                    </Border>
                                </Grid>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Content="{loc:Tr Conflict.ApplyResolve}" Style="{StaticResource AccentButton}" MinWidth="140"
                    Margin="0,0,8,0" Click="OnApply"/>
            <Button Content="{loc:Tr Common.Cancel}" MinWidth="90" IsCancel="True"/>
        </StackPanel>
    </Grid>
</Window>
