<Window x:Class="GitTab.App.Views.ConflictResolverDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:loc="clr-namespace:GitTab.App.Localization"
        Title="{loc:Tr Conflict.Resolve}"
        Icon="pack://application:,,,/GitTab;component/Assets/gittab.ico"
        Width="960" Height="700" MinWidth="680" MinHeight="460"
        WindowStartupLocation="CenterOwner" ShowInTaskbar="False"
        Background="{DynamicResource Brush.Window}" FontFamily="Segoe UI" FontSize="13">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="2*" MinHeight="120"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="3*" MinHeight="160"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,8">
            <TextBlock Text="{Binding DisplayPath}" FontWeight="SemiBold" FontFamily="Consolas" Foreground="{DynamicResource Brush.Text}"/>
            <TextBlock Text="{loc:Tr Conflict.ResolveHint}" Style="{StaticResource MutedText}" TextWrapping="Wrap" Margin="0,4,0,0"/>
        </StackPanel>

        <!-- reference panes: base / ours / theirs -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="6"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="6"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" BorderBrush="{DynamicResource Brush.Border}" BorderThickness="1" CornerRadius="4">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top" Text="{loc:Tr Conflict.Base}" Style="{StaticResource MutedText}"
                               FontSize="11" Margin="6,4" />
                    <TextBox Text="{Binding BaseText, Mode=OneWay}" IsReadOnly="True" FontFamily="Consolas" FontSize="12"
                             Background="Transparent" BorderThickness="0" TextWrapping="NoWrap"
                             VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto"/>
                </DockPanel>
            </Border>

            <Border Grid.Column="2" Background="{DynamicResource Diff.DelBg}" BorderBrush="{DynamicResource Brush.Border}" BorderThickness="1" CornerRadius="4">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top" Text="{loc:Tr Conflict.Ours}" Style="{StaticResource MutedText}"
                               FontSize="11" Margin="6,4"/>
                    <TextBox Text="{Binding Ours, Mode=OneWay}" IsReadOnly="True" FontFamily="Consolas" FontSize="12"
                             Background="Transparent" BorderThickness="0" TextWrapping="NoWrap"
                             VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto"/>
                </DockPanel>
            </Border>

            <Border Grid.Column="4" Background="{DynamicResource Diff.AddBg}" BorderBrush="{DynamicResource Brush.Border}" BorderThickness="1" CornerRadius="4">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top" Text="{loc:Tr Conflict.Theirs}" Style="{StaticResource MutedText}"
                               FontSize="11" Margin="6,4"/>
                    <TextBox Text="{Binding Theirs, Mode=OneWay}" IsReadOnly="True" FontFamily="Consolas" FontSize="12"
                             Background="Transparent" BorderThickness="0" TextWrapping="NoWrap"
                             VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto"/>
                </DockPanel>
            </Border>
        </Grid>

        <!-- quick actions + result header -->
        <Grid Grid.Row="2" Margin="0,10,0,4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Text="{loc:Tr Conflict.Result}" Style="{StaticResource SectionHeader}" VerticalAlignment="Center"/>
            <StackPanel Grid.Column="1" Orientation="Horizontal">
                <Button Content="{loc:Tr Conflict.UseOursAll}" Padding="8,3" Margin="0,0,6,0" Command="{Binding UseOursCommand}"/>
                <Button Content="{loc:Tr Conflict.UseTheirsAll}" Padding="8,3" Margin="0,0,6,0" Command="{Binding UseTheirsCommand}"/>
                <Button Content="{loc:Tr Conflict.KeepBoth}" Padding="8,3" Command="{Binding KeepBothCommand}"/>
            </StackPanel>
        </Grid>

        <!-- editable result -->
        <Border Grid.Row="4" BorderBrush="{DynamicResource Brush.Border}" BorderThickness="1" CornerRadius="4">
            <TextBox Text="{Binding Result, UpdateSourceTrigger=PropertyChanged}" AcceptsReturn="True" AcceptsTab="True"
                     FontFamily="Consolas" FontSize="12.5" Background="Transparent" BorderThickness="0"
                     Foreground="{DynamicResource Brush.Text}" TextWrapping="NoWrap"
                     VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto" Padding="6"/>
        </Border>

        <StackPanel Grid.Row="5" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Content="{loc:Tr Conflict.ApplyResolve}" Style="{StaticResource AccentButton}" MinWidth="150"
                    Margin="0,0,8,0" Click="OnApply"/>
            <Button Content="{loc:Tr Common.Cancel}" MinWidth="90" IsCancel="True"/>
        </StackPanel>
    </Grid>
</Window>
