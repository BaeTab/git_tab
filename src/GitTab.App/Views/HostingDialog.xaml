<Window x:Class="GitTab.App.Views.HostingDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:loc="clr-namespace:GitTab.App.Localization"
        Title="{loc:Tr Hosting.Title}"
        Icon="pack://application:,,,/GitTab;component/Assets/gittab.ico"
        Width="640" Height="520" MinWidth="480" MinHeight="360"
        WindowStartupLocation="CenterOwner" ShowInTaskbar="False"
        Background="{DynamicResource Brush.Window}"
        FontFamily="Segoe UI" FontSize="13">
    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="{loc:Tr Hosting.Title}" FontSize="18" FontWeight="SemiBold"
                   Foreground="{DynamicResource Brush.Text}" Margin="0,0,0,10"/>

        <Grid Grid.Row="1">
            <TextBlock Text="{loc:Tr Hosting.Loading}" Style="{StaticResource MutedText}"
                       HorizontalAlignment="Center" VerticalAlignment="Center"
                       Visibility="{Binding IsLoading, Converter={StaticResource Bool2Vis}}"/>

            <TextBlock Text="{loc:Tr Hosting.Empty}" Style="{StaticResource MutedText}" TextWrapping="Wrap"
                       MaxWidth="360" TextAlignment="Center"
                       HorizontalAlignment="Center" VerticalAlignment="Center"
                       Visibility="{Binding IsEmpty, Converter={StaticResource Bool2Vis}}"/>

            <TabControl Visibility="{Binding HasResults, Converter={StaticResource Bool2Vis}}">
                <TabItem Header="{loc:Tr Hosting.PullRequests}">
                    <Border Style="{StaticResource Card}" Margin="0,10,0,0">
                        <ListBox ItemsSource="{Binding PullRequests}" Background="Transparent" BorderThickness="0"
                                 ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="4,6">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="{Binding Number, StringFormat=#{0}}" FontWeight="SemiBold"
                                                           Foreground="{DynamicResource Brush.Text}" Margin="0,0,6,0"/>
                                                <TextBlock Text="{Binding Title}" FontWeight="SemiBold"
                                                           Foreground="{DynamicResource Brush.Text}" TextTrimming="CharacterEllipsis"/>
                                            </StackPanel>
                                            <TextBlock Style="{StaticResource MutedText}" FontSize="11">
                                                <Run Text="{Binding Author, Mode=OneWay}"/><Run Text=" · "/><Run Text="{Binding State, Mode=OneWay}"/><Run Text=" · "/><Run Text="{Binding SourceBranch, Mode=OneWay}"/>
                                            </TextBlock>
                                        </StackPanel>
                                        <Button Grid.Column="1" Content="{loc:Tr Hosting.Open}" Padding="8,3" VerticalAlignment="Center"
                                                Command="{Binding DataContext.OpenCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                CommandParameter="{Binding Url}"/>
                                    </Grid>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </Border>
                </TabItem>
                <TabItem Header="{loc:Tr Hosting.Issues}">
                    <Border Style="{StaticResource Card}" Margin="0,10,0,0">
                        <ListBox ItemsSource="{Binding Issues}" Background="Transparent" BorderThickness="0"
                                 ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="4,6">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="{Binding Number, StringFormat=#{0}}" FontWeight="SemiBold"
                                                           Foreground="{DynamicResource Brush.Text}" Margin="0,0,6,0"/>
                                                <TextBlock Text="{Binding Title}" FontWeight="SemiBold"
                                                           Foreground="{DynamicResource Brush.Text}" TextTrimming="CharacterEllipsis"/>
                                            </StackPanel>
                                            <TextBlock Style="{StaticResource MutedText}" FontSize="11">
                                                <Run Text="{Binding Author, Mode=OneWay}"/><Run Text=" · "/><Run Text="{Binding State, Mode=OneWay}"/>
                                            </TextBlock>
                                        </StackPanel>
                                        <Button Grid.Column="1" Content="{loc:Tr Hosting.Open}" Padding="8,3" VerticalAlignment="Center"
                                                Command="{Binding DataContext.OpenCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                CommandParameter="{Binding Url}"/>
                                    </Grid>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </Border>
                </TabItem>
            </TabControl>
        </Grid>

        <Button Grid.Row="2" Content="{loc:Tr Common.Close}" IsCancel="True" IsDefault="True" MinWidth="88"
                HorizontalAlignment="Right" Margin="0,14,0,0"/>
    </Grid>
</Window>
