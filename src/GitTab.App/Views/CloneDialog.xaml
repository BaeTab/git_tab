<Window x:Class="GitTab.App.Views.CloneDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:loc="clr-namespace:GitTab.App.Localization"
        Title="{loc:Tr Clone.Title}"
        Icon="pack://application:,,,/GitTab;component/Assets/gittab.ico"
        Width="560" SizeToContent="Height" MinWidth="460"
        WindowStartupLocation="CenterOwner" ShowInTaskbar="False" ResizeMode="NoResize"
        Background="{DynamicResource Brush.Window}"
        FontFamily="Segoe UI" FontSize="13">
    <StackPanel Margin="22">
        <TextBlock Text="{loc:Tr Clone.Title}" FontSize="18" FontWeight="SemiBold"
                   Foreground="{DynamicResource Brush.Text}" Margin="0,0,0,4"/>
        <TextBlock Text="{loc:Tr Clone.Tip}" Style="{StaticResource MutedText}" TextWrapping="Wrap" Margin="0,0,0,14"/>

        <TextBlock Text="{loc:Tr Clone.Url}" Margin="0,0,0,4" Foreground="{DynamicResource Brush.Text}"/>
        <TextBox Text="{Binding Url, UpdateSourceTrigger=PropertyChanged}"/>

        <TextBlock Text="{loc:Tr Clone.Parent}" Margin="0,12,0,4" Foreground="{DynamicResource Brush.Text}"/>
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBox Grid.Column="0" Text="{Binding ParentFolder, UpdateSourceTrigger=PropertyChanged}"/>
            <Button Grid.Column="1" Content="{loc:Tr Repo.Browse}" MinWidth="84" Margin="8,0,0,0" Click="OnBrowse"/>
        </Grid>

        <TextBlock Text="{loc:Tr Clone.FolderName}" Margin="0,12,0,4" Foreground="{DynamicResource Brush.Text}"/>
        <TextBox Text="{Binding FolderName, UpdateSourceTrigger=PropertyChanged}" MaxWidth="280" HorizontalAlignment="Left"/>

        <Border Background="{DynamicResource Brush.SurfaceAlt}" CornerRadius="4" Padding="8,6" Margin="0,12,0,0">
            <TextBlock Foreground="{DynamicResource Brush.TextMuted}" FontFamily="Consolas" TextTrimming="CharacterEllipsis"
                       Text="{Binding TargetPath}"/>
        </Border>

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,18,0,0">
            <Button Content="{loc:Tr Clone.Action}" Style="{StaticResource AccentButton}" IsDefault="True"
                    MinWidth="96" Margin="0,0,8,0" Click="OnClone"/>
            <Button Content="{loc:Tr Common.Cancel}" IsCancel="True" MinWidth="88"/>
        </StackPanel>
    </StackPanel>
</Window>
