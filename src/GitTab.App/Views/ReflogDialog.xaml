<Window x:Class="GitTab.App.Views.ReflogDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:loc="clr-namespace:GitTab.App.Localization"
        Title="{loc:Tr Reflog.Title}"
        Icon="pack://application:,,,/GitTab;component/Assets/gittab.ico"
        Width="680" Height="460" MinWidth="520" MinHeight="320"
        WindowStartupLocation="CenterOwner" ShowInTaskbar="False"
        Background="{DynamicResource Brush.Window}"
        FontFamily="Segoe UI" FontSize="13">
    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,10">
            <TextBlock Text="{loc:Tr Reflog.Title}" FontSize="18" FontWeight="SemiBold" Foreground="{DynamicResource Brush.Text}"/>
            <TextBlock Text="{loc:Tr Reflog.Tip}" Style="{StaticResource MutedText}" TextWrapping="Wrap" Margin="0,2,0,0"/>
        </StackPanel>

        <Border Grid.Row="1" Background="{DynamicResource Brush.SurfaceAlt}" BorderBrush="{DynamicResource Brush.Border}"
                BorderThickness="1" CornerRadius="6">
            <ListBox ItemsSource="{Binding Entries}" Background="Transparent" BorderThickness="0"
                     ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Grid Margin="4,5">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="{Binding ShortSha}" FontFamily="Consolas" Width="64"
                                       Foreground="{DynamicResource Brush.TextMuted}" VerticalAlignment="Center"/>
                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                <TextBlock Text="{Binding Message}" TextTrimming="CharacterEllipsis" Foreground="{DynamicResource Brush.Text}"/>
                                <TextBlock Text="{Binding When, StringFormat='{}{0:yyyy-MM-dd HH:mm}'}" Style="{StaticResource MutedText}" FontSize="11"/>
                            </StackPanel>
                            <TextBlock Grid.Column="2" VerticalAlignment="Center" Margin="8,0,10,0" FontSize="11"
                                       Foreground="{DynamicResource Brush.TextMuted}"
                                       Text="{Binding Index, StringFormat='HEAD@{{{0}}}'}"/>
                            <Button Grid.Column="3" Content="{loc:Tr Reflog.Reset}" Padding="8,3" VerticalAlignment="Center"
                                    Command="{Binding DataContext.RestoreCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                    CommandParameter="{Binding}"/>
                        </Grid>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </Border>

        <Grid Grid.Row="2" Margin="0,12,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <Button Grid.Column="0" HorizontalAlignment="Left" Style="{StaticResource AccentButton}" MinWidth="150"
                    Content="{loc:Tr Reflog.UndoLast}" Command="{Binding UndoLastCommand}" ToolTip="{loc:Tr Reflog.UndoLast.Tip}"/>
            <Button Grid.Column="1" Content="{loc:Tr Common.Close}" IsCancel="True" IsDefault="True" MinWidth="88"/>
        </Grid>
    </Grid>
</Window>
