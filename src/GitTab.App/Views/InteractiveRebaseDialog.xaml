<Window x:Class="GitTab.App.Views.InteractiveRebaseDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:loc="clr-namespace:GitTab.App.Localization"
        Title="Interactive rebase"
        Width="640" Height="520" MinWidth="480" MinHeight="360"
        WindowStartupLocation="CenterOwner" ShowInTaskbar="False"
        Background="{DynamicResource Brush.Window}"
        FontFamily="Segoe UI" FontSize="13"
        x:Name="Root">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,10">
            <TextBlock Text="Interactive rebase" Style="{StaticResource SectionHeader}" Margin="0,0,0,4"/>
            <TextBlock Text="Top = oldest, applied first. Squash/Fixup fold into the row above."
                       Style="{StaticResource MutedText}" TextWrapping="Wrap"/>
        </StackPanel>

        <Border Grid.Row="1" Style="{StaticResource Card}" Padding="4">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <ItemsControl x:Name="RowsList" ItemsSource="{Binding Rows}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Grid Margin="2,3">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="110"/>
                                </Grid.ColumnDefinitions>

                                <Button Grid.Column="0" Content="&#9650;" Style="{StaticResource ToolButton}"
                                        Padding="6,2" FontSize="10" VerticalAlignment="Center"
                                        Command="{Binding DataContext.MoveUpCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                        CommandParameter="{Binding}"/>
                                <Button Grid.Column="1" Content="&#9660;" Style="{StaticResource ToolButton}"
                                        Padding="6,2" FontSize="10" VerticalAlignment="Center" Margin="0,0,8,0"
                                        Command="{Binding DataContext.MoveDownCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                        CommandParameter="{Binding}"/>

                                <Grid Grid.Column="2" Margin="4,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="{Binding ShortSha, Mode=OneWay}" FontFamily="Consolas"
                                               Foreground="{DynamicResource Brush.TextMuted}" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="1" Text="{Binding Summary, Mode=OneWay}" Foreground="{DynamicResource Brush.Text}"
                                               Margin="8,0,0,0" VerticalAlignment="Center"
                                               TextTrimming="CharacterEllipsis" TextWrapping="NoWrap"/>
                                </Grid>

                                <ComboBox Grid.Column="3" Margin="8,0,4,0" VerticalAlignment="Center"
                                          ItemsSource="{Binding DataContext.Actions, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                          SelectedItem="{Binding Action, Mode=TwoWay}"/>
                            </Grid>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Border>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Content="{loc:Tr Common.OK}" Style="{StaticResource AccentButton}" MinWidth="100"
                    Margin="0,0,8,0" Click="OnOk"/>
            <Button Content="{loc:Tr Common.Cancel}" MinWidth="80" IsCancel="True"/>
        </StackPanel>
    </Grid>
</Window>
