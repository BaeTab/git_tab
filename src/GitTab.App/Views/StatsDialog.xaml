<Window x:Class="GitTab.App.Views.StatsDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:loc="clr-namespace:GitTab.App.Localization"
        Title="{loc:Tr Stats.Title}"
        Icon="pack://application:,,,/GitTab;component/Assets/gittab.ico"
        Width="560" Height="560" MinWidth="440" MinHeight="400"
        WindowStartupLocation="CenterOwner" ShowInTaskbar="False"
        Background="{DynamicResource Brush.Window}"
        FontFamily="Segoe UI" FontSize="13">
    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="{loc:Tr Stats.Title}" FontSize="18" FontWeight="SemiBold"
                   Foreground="{DynamicResource Brush.Text}" Margin="0,0,0,10"/>

        <!-- summary cards -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Style="{StaticResource Card}" Margin="0,0,6,0" Padding="12,10">
                <StackPanel>
                    <TextBlock Text="{Binding CommitCount}" FontSize="22" FontWeight="SemiBold"
                               Foreground="{DynamicResource Brush.Text}"/>
                    <TextBlock Text="{loc:Tr Stats.Commits}" Style="{StaticResource MutedText}" Margin="0,2,0,0"/>
                </StackPanel>
            </Border>

            <Border Grid.Column="1" Style="{StaticResource Card}" Margin="6,0,6,0" Padding="12,10">
                <StackPanel>
                    <TextBlock Text="{Binding BranchCount}" FontSize="22" FontWeight="SemiBold"
                               Foreground="{DynamicResource Brush.Text}"/>
                    <TextBlock Text="{loc:Tr Stats.Branches}" Style="{StaticResource MutedText}" Margin="0,2,0,0"/>
                </StackPanel>
            </Border>

            <Border Grid.Column="2" Style="{StaticResource Card}" Margin="6,0,0,0" Padding="12,10">
                <StackPanel>
                    <TextBlock Text="{Binding TagCount}" FontSize="22" FontWeight="SemiBold"
                               Foreground="{DynamicResource Brush.Text}"/>
                    <TextBlock Text="{loc:Tr Stats.Tags}" Style="{StaticResource MutedText}" Margin="0,2,0,0"/>
                </StackPanel>
            </Border>
        </Grid>

        <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,10,0,0">
            <TextBlock Text="{loc:Tr Stats.LastActivity}" Style="{StaticResource MutedText}"/>
            <TextBlock Text="{Binding LastActivity}" Foreground="{DynamicResource Brush.Text}" Margin="6,0,0,0"/>
        </StackPanel>

        <!-- contributors -->
        <Grid Grid.Row="3" Margin="0,14,0,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Text="{loc:Tr Stats.Contributors}" FontWeight="SemiBold"
                       Foreground="{DynamicResource Brush.Text}" Margin="0,0,0,6"/>

            <Grid Grid.Row="1">
                <TextBlock Text="{loc:Tr Stats.Loading}" Style="{StaticResource MutedText}"
                           HorizontalAlignment="Center" VerticalAlignment="Center"
                           Visibility="{Binding IsLoading, Converter={StaticResource Bool2Vis}}"/>

                <Border Style="{StaticResource Card}"
                        Visibility="{Binding IsLoading, Converter={StaticResource Bool2Vis}, ConverterParameter=invert}">
                    <ListBox ItemsSource="{Binding Contributors}" Background="Transparent" BorderThickness="0"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="4,6">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="{Binding Name}" FontWeight="SemiBold"
                                                       Foreground="{DynamicResource Brush.Text}"/>
                                            <TextBlock Text="{Binding Email}" Style="{StaticResource MutedText}"
                                                       TextTrimming="CharacterEllipsis" Margin="6,0,0,0"/>
                                        </StackPanel>
                                        <ProgressBar Minimum="0" Maximum="1" Value="{Binding Fraction, Mode=OneWay}"
                                                     Height="4" Margin="0,4,0,0" BorderThickness="0"
                                                     Foreground="{DynamicResource Brush.Accent}"
                                                     Background="{DynamicResource Brush.SurfaceAlt}"/>
                                    </StackPanel>
                                    <TextBlock Grid.Column="1" Text="{Binding Commits}" VerticalAlignment="Center"
                                               Foreground="{DynamicResource Brush.Text}" Margin="10,0,0,0"/>
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Border>
            </Grid>
        </Grid>

        <Button Grid.Row="4" Content="{loc:Tr Common.Close}" IsCancel="True" IsDefault="True" MinWidth="88"
                HorizontalAlignment="Right" Margin="0,14,0,0"/>
    </Grid>
</Window>
