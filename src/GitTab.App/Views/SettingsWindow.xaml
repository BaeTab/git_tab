<Window x:Class="GitTab.App.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:loc="clr-namespace:GitTab.App.Localization"
        Title="{loc:Tr Settings.Title}"
        Width="480" SizeToContent="Height" MinWidth="420"
        WindowStartupLocation="CenterOwner" ShowInTaskbar="False" ResizeMode="NoResize"
        Background="{DynamicResource Brush.Window}"
        FontFamily="Segoe UI" FontSize="13">
    <StackPanel Margin="22">
        <TextBlock Text="{loc:Tr Settings.Title}" FontSize="18" FontWeight="SemiBold"
                   Foreground="{DynamicResource Brush.Text}" Margin="0,0,0,16"/>

        <!-- Appearance -->
        <TextBlock Text="{loc:Tr Settings.Appearance}" Style="{StaticResource SectionHeader}"/>
        <StackPanel Orientation="Horizontal" Margin="0,8,0,6">
            <TextBlock Text="{loc:Tr Settings.Theme}" Width="96" VerticalAlignment="Center" Foreground="{DynamicResource Brush.Text}"/>
            <RadioButton GroupName="theme" Content="{loc:Tr Theme.Light}" Margin="0,0,18,0"
                         IsChecked="{Binding IsLightTheme, Mode=TwoWay}" Foreground="{DynamicResource Brush.Text}"/>
            <RadioButton GroupName="theme" Content="{loc:Tr Theme.Dark}"
                         IsChecked="{Binding IsDarkTheme, Mode=TwoWay}" Foreground="{DynamicResource Brush.Text}"/>
        </StackPanel>
        <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
            <TextBlock Text="{loc:Tr Language}" Width="96" VerticalAlignment="Center" Foreground="{DynamicResource Brush.Text}"/>
            <RadioButton GroupName="lang" Content="{loc:Tr Language.Korean}" Margin="0,0,18,0"
                         IsChecked="{Binding IsKoreanLanguage, Mode=TwoWay}" Foreground="{DynamicResource Brush.Text}"/>
            <RadioButton GroupName="lang" Content="{loc:Tr Language.English}"
                         IsChecked="{Binding IsEnglishLanguage, Mode=TwoWay}" Foreground="{DynamicResource Brush.Text}"/>
        </StackPanel>

        <!-- Explorer integration -->
        <TextBlock Text="{loc:Tr Settings.ShellSection}" Style="{StaticResource SectionHeader}" Margin="0,12,0,0"/>
        <CheckBox Content="{loc:Tr Settings.ShellEnable}" Margin="0,8,0,2"
                  IsChecked="{Binding IsShellIntegrationInstalled, Mode=OneWay}"
                  Command="{Binding ToggleShellIntegrationCommand}"
                  Foreground="{DynamicResource Brush.Text}"/>
        <TextBlock Text="{loc:Tr Shell.Tip}" Style="{StaticResource MutedText}" TextWrapping="Wrap" Margin="0,0,0,4"/>

        <!-- Git executable -->
        <TextBlock Text="{loc:Tr Settings.GitSection}" Style="{StaticResource SectionHeader}" Margin="0,14,0,0"/>
        <TextBox Text="{Binding GitPath, Mode=OneWay}" IsReadOnly="True" Margin="0,8,0,4"/>

        <!-- Authentication -->
        <TextBlock Text="{loc:Tr Settings.AuthSection}" Style="{StaticResource SectionHeader}" Margin="0,14,0,0"/>
        <TextBlock Text="{loc:Tr Settings.ClearCredTip}" Style="{StaticResource MutedText}" TextWrapping="Wrap" Margin="0,8,0,6"/>
        <Button Content="{loc:Tr Settings.ClearCred}" Command="{Binding ClearCredentialsCommand}" HorizontalAlignment="Left"/>

        <!-- Diagnostics -->
        <TextBlock Text="{loc:Tr Settings.Diagnostics}" Style="{StaticResource SectionHeader}" Margin="0,14,0,0"/>
        <CheckBox Content="{loc:Tr Settings.CrashReports}" Margin="0,8,0,2"
                  IsChecked="{Binding CrashReportsEnabled, Mode=TwoWay}" Foreground="{DynamicResource Brush.Text}"/>
        <TextBlock Text="{loc:Tr Settings.CrashReports.Tip}" Style="{StaticResource MutedText}" TextWrapping="Wrap" Margin="0,0,0,6"/>
        <Button Content="{loc:Tr Settings.OpenLogs}" Command="{Binding OpenLogsFolderCommand}" HorizontalAlignment="Left"/>

        <!-- About -->
        <TextBlock Text="{loc:Tr Settings.About}" Style="{StaticResource SectionHeader}" Margin="0,16,0,0"/>
        <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
            <TextBlock Text="{loc:Tr App.Title}" FontWeight="SemiBold" Foreground="{DynamicResource Brush.Text}"/>
            <TextBlock Text="{Binding AppVersion, StringFormat=v{0}}" Margin="8,0,0,0" Style="{StaticResource MutedText}"/>
        </StackPanel>
        <TextBlock Margin="0,3,0,0">
            <Hyperlink NavigateUri="https://github.com/BaeTab/git_tab" RequestNavigate="OnNavigate">
                github.com/BaeTab/git_tab
            </Hyperlink>
        </TextBlock>

        <Button Content="{loc:Tr Common.Close}" IsCancel="True" IsDefault="True"
                HorizontalAlignment="Right" MinWidth="88" Margin="0,20,0,0"/>
    </StackPanel>
</Window>
