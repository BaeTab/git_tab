<Window x:Class="GitTab.App.Views.ChangelogDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:loc="clr-namespace:GitTab.App.Localization"
        Title="{loc:Tr Changelog.Title}"
        Icon="pack://application:,,,/GitTab;component/Assets/gittab.ico"
        Width="680" Height="620" MinWidth="480" MinHeight="380"
        WindowStartupLocation="CenterOwner" ShowInTaskbar="False"
        Background="{DynamicResource Brush.Window}"
        FontFamily="Segoe UI" FontSize="13">
    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,10">
            <TextBlock Text="{loc:Tr Changelog.From}" VerticalAlignment="Center" Margin="0,0,6,0" Foreground="{DynamicResource Brush.Text}"/>
            <ComboBox ItemsSource="{Binding FromRefs}" SelectedItem="{Binding SelectedFromRef}" MinWidth="220"/>
            <Button Content="{loc:Tr Changelog.Generate}" Command="{Binding GenerateCommand}" Padding="10,3" Margin="10,0,0,0"/>
        </StackPanel>

        <Border Grid.Row="1" Background="{DynamicResource Brush.SurfaceAlt}" BorderBrush="{DynamicResource Brush.Border}"
                BorderThickness="1" CornerRadius="6">
            <TextBox Text="{Binding Output, Mode=OneWay}" IsReadOnly="True" IsReadOnlyCaretVisible="True"
                     FontFamily="Consolas" FontSize="12.5" Background="Transparent" BorderThickness="0"
                     Padding="8" AcceptsReturn="True" TextWrapping="NoWrap"
                     VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto"/>
        </Border>

        <Grid Grid.Row="2" Margin="0,12,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <Button Grid.Column="1" Content="{loc:Tr Changelog.Copy}" Command="{Binding CopyCommand}" Padding="10,3" Margin="0,0,8,0" MinWidth="88"/>
            <Button Grid.Column="2" Content="{loc:Tr Changelog.Save}" Style="{StaticResource AccentButton}" Command="{Binding SaveCommand}" Padding="10,3" Margin="0,0,8,0" MinWidth="88"/>
            <Button Grid.Column="3" Content="{loc:Tr Common.Close}" IsCancel="True" IsDefault="True" MinWidth="88"/>
        </Grid>
    </Grid>
</Window>
