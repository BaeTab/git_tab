<Window x:Class="GitTab.App.Views.GitignoreDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:loc="clr-namespace:GitTab.App.Localization"
        Title="{loc:Tr Gitignore.Title}"
        Width="620" Height="520" MinWidth="480" MinHeight="360"
        WindowStartupLocation="CenterOwner" ShowInTaskbar="False"
        Background="{DynamicResource Brush.Window}"
        FontFamily="Segoe UI" FontSize="13">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0">
            <TextBlock Text="{loc:Tr Gitignore.Tip}" TextWrapping="Wrap" Foreground="{DynamicResource Brush.Text}"/>
            <TextBlock Text="{loc:Tr Gitignore.Detected}" Style="{StaticResource SectionHeader}" Margin="0,10,0,4"/>
        </StackPanel>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="220"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- stack checkboxes -->
            <Border Grid.Column="0" Style="{StaticResource Card}" Padding="8" Margin="0,0,8,0">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <ItemsControl ItemsSource="{Binding Choices}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <CheckBox Content="{Binding Name}" IsChecked="{Binding IsSelected}"
                                          Margin="2,4" Foreground="{DynamicResource Brush.Text}"/>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Border>

            <!-- preview -->
            <Border Grid.Column="1" Style="{StaticResource Card}" Padding="2">
                <TextBox Text="{Binding PreviewText, Mode=OneWay}" IsReadOnly="True"
                         FontFamily="Consolas" FontSize="12"
                         VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto"
                         TextWrapping="NoWrap" BorderThickness="0" Background="Transparent"/>
            </Border>
        </Grid>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <TextBlock Text="{loc:Tr Gitignore.Exists}" Style="{StaticResource MutedText}" VerticalAlignment="Center"
                       Margin="0,0,12,0" MaxWidth="240" TextWrapping="Wrap"
                       Visibility="{Binding HasExisting, Converter={StaticResource Bool2Vis}}"/>
            <Button Content="{loc:Tr Gitignore.Append}" MinWidth="120" Margin="0,0,8,0"
                    Click="OnAppend" IsEnabled="{Binding HasExisting}"/>
            <Button Content="{loc:Tr Gitignore.Write}" Style="{StaticResource AccentButton}" MinWidth="120"
                    Margin="0,0,8,0" Click="OnWrite"/>
            <Button Content="{loc:Tr Common.Cancel}" MinWidth="80" IsCancel="True"/>
        </StackPanel>
    </Grid>
</Window>
