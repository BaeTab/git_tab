<Window x:Class="GitTab.App.Views.NewRepositoryDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:loc="clr-namespace:GitTab.App.Localization"
        Title="{loc:Tr Repo.Create}"
        Icon="pack://application:,,,/GitTab;component/Assets/gittab.ico"
        Width="520" SizeToContent="Height" MinWidth="440"
        WindowStartupLocation="CenterOwner" ShowInTaskbar="False" ResizeMode="NoResize"
        Background="{DynamicResource Brush.Window}"
        FontFamily="Segoe UI" FontSize="13">
    <StackPanel Margin="20">
        <TextBlock Text="{loc:Tr Repo.Create}" FontSize="18" FontWeight="SemiBold"
                   Foreground="{DynamicResource Brush.Text}" Margin="0,0,0,4"/>
        <TextBlock Text="{loc:Tr Repo.Create.Tip}" Style="{StaticResource MutedText}" TextWrapping="Wrap" Margin="0,0,0,14"/>

        <TextBlock Text="{loc:Tr Repo.Folder}" Margin="0,0,0,4" Foreground="{DynamicResource Brush.Text}"/>
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBox Grid.Column="0" Text="{Binding FolderPath, UpdateSourceTrigger=PropertyChanged}"/>
            <Button Grid.Column="1" Content="{loc:Tr Repo.Browse}" MinWidth="84" Margin="8,0,0,0" Click="OnBrowse"/>
        </Grid>

        <TextBlock Text="{loc:Tr Repo.InitialBranch}" Margin="0,12,0,4" Foreground="{DynamicResource Brush.Text}"/>
        <TextBox Text="{Binding InitialBranch, UpdateSourceTrigger=PropertyChanged}" MaxWidth="220" HorizontalAlignment="Left"/>

        <TextBlock Text="{loc:Tr Repo.RemoteOptional}" Margin="0,12,0,4" Foreground="{DynamicResource Brush.Text}"/>
        <TextBox Text="{Binding RemoteUrl, UpdateSourceTrigger=PropertyChanged}"/>
        <TextBlock Text="{loc:Tr Repo.Remote.Tip}" Style="{StaticResource MutedText}" TextWrapping="Wrap" Margin="0,4,0,0"/>

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,18,0,0">
            <Button Content="{loc:Tr Repo.Create}" Style="{StaticResource AccentButton}" IsDefault="True"
                    MinWidth="96" Margin="0,0,8,0" Click="OnCreate"/>
            <Button Content="{loc:Tr Common.Cancel}" IsCancel="True" MinWidth="88"/>
        </StackPanel>
    </StackPanel>
</Window>
