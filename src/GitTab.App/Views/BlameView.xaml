<Window x:Class="GitTab.App.Views.BlameView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:loc="clr-namespace:GitTab.App.Localization"
        Width="1000" Height="700" MinWidth="640" MinHeight="360"
        WindowStartupLocation="CenterOwner" ShowInTaskbar="False"
        Background="{DynamicResource Brush.Window}"
        FontFamily="Segoe UI" FontSize="13">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header: file path -->
        <StackPanel Grid.Row="0" Margin="0,0,0,10">
            <TextBlock Text="{Binding FilePath}"
                       FontSize="14" FontWeight="SemiBold"
                       Foreground="{DynamicResource Brush.Text}"
                       TextTrimming="CharacterEllipsis"/>
        </StackPanel>

        <!-- Blame lines -->
        <Border Grid.Row="1" Style="{StaticResource Card}" Padding="0">
            <ListView x:Name="LinesList"
                      ItemsSource="{Binding Rows}"
                      Background="Transparent"
                      BorderThickness="0"
                      ScrollViewer.HorizontalScrollBarVisibility="Auto"
                      ScrollViewer.VerticalScrollBarVisibility="Auto"
                      ScrollViewer.CanContentScroll="True"
                      VirtualizingStackPanel.IsVirtualizing="True"
                      VirtualizingStackPanel.VirtualizationMode="Recycling"
                      VirtualizingPanel.ScrollUnit="Pixel">
                <ListView.ItemContainerStyle>
                    <Style TargetType="ListViewItem">
                        <Setter Property="Background" Value="{DynamicResource Brush.Surface}"/>
                        <Setter Property="Foreground" Value="{DynamicResource Brush.Text}"/>
                        <Setter Property="Padding" Value="10,2"/>
                        <Setter Property="BorderThickness" Value="0"/>
                        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                        <Setter Property="Focusable" Value="False"/>
                        <Setter Property="ToolTip" Value="{Binding Line.Summary}"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ListViewItem">
                                    <Border Background="{TemplateBinding Background}"
                                            Padding="{TemplateBinding Padding}">
                                        <ContentPresenter/>
                                    </Border>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding Band}" Value="True">
                                <Setter Property="Background" Value="{DynamicResource Brush.SurfaceAlt}"/>
                            </DataTrigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{DynamicResource Brush.Hover}"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </ListView.ItemContainerStyle>
                <ListView.ItemTemplate>
                    <DataTemplate>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="44"/>
                                <ColumnDefinition Width="72"/>
                                <ColumnDefinition Width="120"/>
                                <ColumnDefinition Width="90"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Column="0"
                                       Text="{Binding Line.LineNumber}"
                                       FontFamily="Consolas" FontSize="12"
                                       Foreground="{DynamicResource Brush.TextMuted}"
                                       HorizontalAlignment="Right" VerticalAlignment="Center"
                                       Margin="0,0,10,0"/>

                            <TextBlock Grid.Column="1"
                                       Text="{Binding Line.ShortSha}"
                                       FontFamily="Consolas" FontSize="12"
                                       Foreground="{DynamicResource Brush.TextMuted}"
                                       VerticalAlignment="Center"
                                       Margin="0,0,10,0"/>

                            <TextBlock Grid.Column="2"
                                       Text="{Binding Line.Author}"
                                       FontFamily="Consolas" FontSize="12"
                                       Foreground="{DynamicResource Brush.Text}"
                                       VerticalAlignment="Center"
                                       TextTrimming="CharacterEllipsis"
                                       Margin="0,0,10,0"/>

                            <TextBlock Grid.Column="3"
                                       Text="{Binding Line.When, StringFormat=yyyy-MM-dd}"
                                       FontFamily="Consolas" FontSize="12"
                                       Foreground="{DynamicResource Brush.TextMuted}"
                                       VerticalAlignment="Center"
                                       Margin="0,0,12,0"/>

                            <TextBlock Grid.Column="4"
                                       Text="{Binding Line.Content}"
                                       FontFamily="Consolas" FontSize="12"
                                       Foreground="{DynamicResource Brush.Text}"
                                       VerticalAlignment="Center"
                                       TextWrapping="NoWrap"/>
                        </Grid>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>
        </Border>

        <!-- Bottom bar -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Content="{loc:Tr Common.Close}" MinWidth="90" IsCancel="True"/>
        </StackPanel>
    </Grid>
</Window>
