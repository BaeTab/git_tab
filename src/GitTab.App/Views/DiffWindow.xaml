<Window x:Class="GitTab.App.Views.DiffWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:GitTab.App.Controls"
        xmlns:loc="clr-namespace:GitTab.App.Localization"
        Title="{loc:Tr Diff.PopOut}"
        Height="720" Width="1000" MinHeight="300" MinWidth="480"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource Brush.Window}"
        TextOptions.TextFormattingMode="Ideal"
        FontFamily="Segoe UI" FontSize="13">
    <DockPanel>
        <Border DockPanel.Dock="Top" Background="{DynamicResource Brush.Surface}"
                BorderBrush="{DynamicResource Brush.Border}" BorderThickness="0,0,0,1" Padding="6,3">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button x:Name="FullScreenButton" Content="{loc:Tr Diff.FullScreen}" Click="OnToggleFull"
                        Padding="8,2" Cursor="Hand" Foreground="{DynamicResource Brush.Text}"
                        ToolTip="{loc:Tr Diff.FullScreen.Tip}"/>
            </StackPanel>
        </Border>
        <controls:DiffView x:Name="Diff"/>
    </DockPanel>
</Window>
