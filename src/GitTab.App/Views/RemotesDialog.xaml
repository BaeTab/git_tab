<Window x:Class="GitTab.App.Views.RemotesDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:loc="clr-namespace:GitTab.App.Localization"
        Title="{loc:Tr Remote.Manage}"
        Icon="pack://application:,,,/GitTab;component/Assets/gittab.ico"
        Width="600" Height="420" MinWidth="460" MinHeight="300"
        WindowStartupLocation="CenterOwner" ShowInTaskbar="False"
        Background="{DynamicResource Brush.Window}"
        FontFamily="Segoe UI" FontSize="13">
    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,10">
            <TextBlock Text="{loc:Tr Remote.Manage}" FontSize="18" FontWeight="SemiBold" Foreground="{DynamicResource Brush.Text}"/>
            <TextBlock Text="{loc:Tr Remote.Tip}" Style="{StaticResource MutedText}" TextWrapping="Wrap" Margin="0,2,0,0"/>
        </StackPanel>

        <Border Grid.Row="1" Background="{DynamicResource Brush.SurfaceAlt}" BorderBrush="{DynamicResource Brush.Border}"
                BorderThickness="1" CornerRadius="6">
            <ListBox ItemsSource="{Binding Remotes}" Background="Transparent" BorderThickness="0"
                     ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Grid Margin="4,6">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                <TextBlock Text="{Binding Name}" FontWeight="SemiBold" Foreground="{DynamicResource Brush.Text}"/>
                                <TextBlock Text="{Binding Url}" Style="{StaticResource MutedText}" TextTrimming="CharacterEllipsis"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                <Button Content="{loc:Tr Remote.EditUrl}" Padding="8,3" Margin="0,0,6,0"
                                        Command="{Binding DataContext.EditUrlCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                        CommandParameter="{Binding}"/>
                                <Button Content="{loc:Tr Common.Delete}" Padding="8,3"
                                        Command="{Binding DataContext.RemoveCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                        CommandParameter="{Binding}"/>
                            </StackPanel>
                        </Grid>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </Border>

        <Grid Grid.Row="2" Margin="0,12,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <Button Grid.Column="0" HorizontalAlignment="Left" Style="{StaticResource AccentButton}" MinWidth="130"
                    Content="{loc:Tr Remote.Add}" Command="{Binding AddCommand}"/>
            <Button Grid.Column="1" Content="{loc:Tr Common.Close}" IsCancel="True" IsDefault="True" MinWidth="88"/>
        </Grid>
    </Grid>
</Window>
