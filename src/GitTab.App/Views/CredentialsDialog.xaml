<Window x:Class="GitTab.App.Views.CredentialsDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:loc="clr-namespace:GitTab.App.Localization"
        Title="{loc:Tr Cred.Manage}"
        Icon="pack://application:,,,/GitTab;component/Assets/gittab.ico"
        Width="560" Height="420" MinWidth="440" MinHeight="300"
        WindowStartupLocation="CenterOwner" ShowInTaskbar="False"
        Background="{DynamicResource Brush.Window}"
        FontFamily="Segoe UI" FontSize="13">
    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,10">
            <TextBlock Text="{loc:Tr Cred.Manage}" FontSize="18" FontWeight="SemiBold" Foreground="{DynamicResource Brush.Text}"/>
            <TextBlock Text="{loc:Tr Cred.Tip}" Style="{StaticResource MutedText}" TextWrapping="Wrap" Margin="0,2,0,0"/>
        </StackPanel>

        <Grid Grid.Row="1">
            <Border Background="{DynamicResource Brush.SurfaceAlt}" BorderBrush="{DynamicResource Brush.Border}"
                    BorderThickness="1" CornerRadius="6">
                <ListBox ItemsSource="{Binding Credentials}" Background="Transparent" BorderThickness="0"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Grid Margin="4,6">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="{Binding}" FontWeight="SemiBold" VerticalAlignment="Center"
                                           Foreground="{DynamicResource Brush.Text}" TextTrimming="CharacterEllipsis"/>
                                <Button Grid.Column="1" Content="{loc:Tr Common.Delete}" Padding="8,3"
                                        Command="{Binding DataContext.DeleteCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                        CommandParameter="{Binding}"/>
                            </Grid>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Border>

            <TextBlock Text="{loc:Tr Cred.Empty}" Style="{StaticResource MutedText}" TextWrapping="Wrap"
                       HorizontalAlignment="Center" VerticalAlignment="Center"
                       Visibility="{Binding IsEmpty, Converter={StaticResource Bool2Vis}}"/>
        </Grid>

        <Grid Grid.Row="2" Margin="0,12,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <Button Grid.Column="1" Content="{loc:Tr Common.Close}" IsCancel="True" IsDefault="True" MinWidth="88"/>
        </Grid>
    </Grid>
</Window>
