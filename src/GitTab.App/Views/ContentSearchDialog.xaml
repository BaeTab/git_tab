<Window x:Class="GitTab.App.Views.ContentSearchDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:loc="clr-namespace:GitTab.App.Localization"
        Title="{loc:Tr Search.Content}"
        Icon="pack://application:,,,/GitTab;component/Assets/gittab.ico"
        Width="680" Height="520" MinWidth="520" MinHeight="360"
        WindowStartupLocation="CenterOwner" ShowInTaskbar="False"
        Background="{DynamicResource Brush.Window}" FontFamily="Segoe UI" FontSize="13">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,4">
            <TextBlock Text="{loc:Tr Search.Content}" FontSize="17" FontWeight="SemiBold" Foreground="{DynamicResource Brush.Text}"/>
            <TextBlock Text="{loc:Tr Search.Content.Tip}" Style="{StaticResource MutedText}" TextWrapping="Wrap" Margin="0,2,0,0"/>
        </StackPanel>

        <Grid Grid.Row="1" Margin="0,8,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBox x:Name="TermBox" Grid.Column="0" Text="{Binding Term, UpdateSourceTrigger=PropertyChanged}"
                     KeyDown="OnTermKeyDown"/>
            <CheckBox Grid.Column="1" Content="{loc:Tr Search.Regex}" IsChecked="{Binding UseRegex}"
                      VerticalAlignment="Center" Margin="10,0" Foreground="{DynamicResource Brush.Text}"/>
            <Button Grid.Column="2" Content="{loc:Tr Search.Run}" Style="{StaticResource AccentButton}" MinWidth="80"
                    Command="{Binding SearchCommand}"/>
        </Grid>

        <Border Grid.Row="2" Style="{StaticResource Card}">
            <Grid>
                <ListBox ItemsSource="{Binding Results}" Background="Transparent" BorderThickness="0"
                         MouseDoubleClick="OnResultDoubleClick">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Margin="2,4">
                                <TextBlock Text="{Binding Summary}" TextTrimming="CharacterEllipsis" Foreground="{DynamicResource Brush.Text}"/>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="{Binding ShortSha}" FontFamily="Consolas" Style="{StaticResource MutedText}" FontSize="11"/>
                                    <TextBlock Text="{Binding Author}" Style="{StaticResource MutedText}" FontSize="11" Margin="8,0,0,0"/>
                                    <TextBlock Text="{Binding WhenText}" Style="{StaticResource MutedText}" FontSize="11" Margin="8,0,0,0"/>
                                </StackPanel>
                            </StackPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
                <TextBlock Text="{loc:Tr Search.Empty}" Style="{StaticResource MutedText}"
                           HorizontalAlignment="Center" VerticalAlignment="Center"
                           Visibility="{Binding ShowEmpty, Converter={StaticResource Bool2Vis}}"/>
            </Grid>
        </Border>

        <TextBlock Grid.Row="3" Text="{loc:Tr Search.DblClick}" Style="{StaticResource MutedText}" Margin="2,8,0,0"/>
    </Grid>
</Window>
