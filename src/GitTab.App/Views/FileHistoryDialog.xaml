<Window x:Class="GitTab.App.Views.FileHistoryDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:loc="clr-namespace:GitTab.App.Localization"
        xmlns:controls="clr-namespace:GitTab.App.Controls"
        Title="{loc:Tr FileHistory.Title}"
        Icon="pack://application:,,,/GitTab;component/Assets/gittab.ico"
        Width="1000" Height="640" MinWidth="720" MinHeight="420"
        WindowStartupLocation="CenterOwner" ShowInTaskbar="False"
        Background="{DynamicResource Brush.Window}" FontFamily="Segoe UI" FontSize="13">
    <Grid Margin="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,8">
            <TextBlock Text="{loc:Tr FileHistory.Title}" FontSize="17" FontWeight="SemiBold" Foreground="{DynamicResource Brush.Text}"/>
            <TextBlock Text="{Binding FilePath}" Style="{StaticResource MutedText}" FontFamily="Consolas"
                       VerticalAlignment="Bottom" Margin="10,0,0,2" TextTrimming="CharacterEllipsis"/>
        </StackPanel>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="360" MinWidth="240"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*" MinWidth="300"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Style="{StaticResource Card}">
                <ListBox ItemsSource="{Binding Entries}" SelectedItem="{Binding SelectedEntry}"
                         Background="Transparent" BorderThickness="0">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Margin="2,4">
                                <TextBlock Text="{Binding Summary}" TextTrimming="CharacterEllipsis" Foreground="{DynamicResource Brush.Text}"/>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="{Binding ShortSha}" FontFamily="Consolas" Style="{StaticResource MutedText}" FontSize="11"/>
                                    <TextBlock Text="{Binding Author}" Style="{StaticResource MutedText}" FontSize="11" Margin="8,0,0,0"/>
                                    <TextBlock Text="{Binding WhenText}" Style="{StaticResource MutedText}" FontSize="11" Margin="8,0,0,0"/>
                                </StackPanel>
                            </StackPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Border>

            <GridSplitter Grid.Column="1" Width="6" HorizontalAlignment="Center" VerticalAlignment="Stretch"
                          Background="Transparent"/>

            <Border Grid.Column="2" Style="{StaticResource Card}">
                <controls:DiffView DataContext="{Binding Diff}"/>
            </Border>
        </Grid>
    </Grid>
</Window>
