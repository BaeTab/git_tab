<UserControl x:Class="GitTab.App.Controls.DiffView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:loc="clr-namespace:GitTab.App.Localization"
             xmlns:avalon="http://icsharpcode.net/sharpdevelop/avalonedit">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- toolbar: ignore-whitespace + split/unified toggle -->
        <Border Grid.Row="0" Background="{DynamicResource Brush.Surface}" Padding="6,3"
                Visibility="{Binding HasContent, Converter={StaticResource Bool2Vis}}">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <CheckBox Content="{loc:Tr Diff.IgnoreWhitespace}" IsChecked="{Binding IgnoreWhitespace}"
                          VerticalAlignment="Center" Margin="0,0,12,0"
                          Foreground="{DynamicResource Brush.Text}"/>
                <ToggleButton Content="{loc:Tr Diff.Split}" IsChecked="{Binding IsSplit}"
                              ToolTip="{loc:Tr Diff.SplitTip}"
                              Foreground="{DynamicResource Brush.Text}" Padding="8,2" Cursor="Hand"/>
            </StackPanel>
        </Border>

        <Grid Grid.Row="1">
            <!-- unified -->
            <avalon:TextEditor x:Name="Editor"
                               IsReadOnly="True" FontFamily="Consolas" FontSize="12.5"
                               WordWrap="False" ShowLineNumbers="False"
                               Background="{DynamicResource Brush.Surface}" Foreground="{DynamicResource Brush.Text}"
                               HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto"/>

            <!-- side-by-side -->
            <Grid x:Name="SplitRoot" Visibility="Collapsed">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="1"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <avalon:TextEditor x:Name="LeftEditor" Grid.Column="0"
                                   IsReadOnly="True" FontFamily="Consolas" FontSize="12.5"
                                   WordWrap="False" ShowLineNumbers="False"
                                   Background="{DynamicResource Brush.Surface}" Foreground="{DynamicResource Brush.Text}"
                                   HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto"/>
                <Border Grid.Column="1" Background="{DynamicResource Brush.Border}"/>
                <avalon:TextEditor x:Name="RightEditor" Grid.Column="2"
                                   IsReadOnly="True" FontFamily="Consolas" FontSize="12.5"
                                   WordWrap="False" ShowLineNumbers="False"
                                   Background="{DynamicResource Brush.Surface}" Foreground="{DynamicResource Brush.Text}"
                                   HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto"/>
            </Grid>

            <!-- image before/after -->
            <Grid Background="{DynamicResource Brush.Surface}"
                  Visibility="{Binding IsImage, Converter={StaticResource Bool2Vis}}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="1"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <DockPanel Grid.Column="0" Margin="8">
                    <TextBlock DockPanel.Dock="Top" Text="{loc:Tr Diff.ImageOld}" Style="{StaticResource MutedText}"
                               HorizontalAlignment="Center" Margin="0,0,0,6"/>
                    <Border Background="{DynamicResource Brush.SurfaceAlt}" BorderBrush="{DynamicResource Brush.Border}" BorderThickness="1">
                        <Image Source="{Binding OldImage}" Stretch="Uniform" StretchDirection="DownOnly" Margin="6"/>
                    </Border>
                </DockPanel>
                <Border Grid.Column="1" Background="{DynamicResource Brush.Border}"/>
                <DockPanel Grid.Column="2" Margin="8">
                    <TextBlock DockPanel.Dock="Top" Text="{loc:Tr Diff.ImageNew}" Style="{StaticResource MutedText}"
                               HorizontalAlignment="Center" Margin="0,0,0,6"/>
                    <Border Background="{DynamicResource Brush.SurfaceAlt}" BorderBrush="{DynamicResource Brush.Border}" BorderThickness="1">
                        <Image Source="{Binding NewImage}" Stretch="Uniform" StretchDirection="DownOnly" Margin="6"/>
                    </Border>
                </DockPanel>
            </Grid>

            <!-- placeholder -->
            <Border Background="{DynamicResource Brush.Surface}"
                    Visibility="{Binding ShowPlaceholder, Converter={StaticResource Bool2Vis}}">
                <TextBlock Text="{Binding PlaceholderText}" Style="{StaticResource MutedText}"
                           TextWrapping="Wrap" MaxWidth="360"
                           HorizontalAlignment="Center" VerticalAlignment="Center" TextAlignment="Center"/>
            </Border>
        </Grid>
    </Grid>
</UserControl>
