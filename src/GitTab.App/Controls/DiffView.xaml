<UserControl x:Class="GitTab.App.Controls.DiffView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:loc="clr-namespace:GitTab.App.Localization"
             xmlns:avalon="http://icsharpcode.net/sharpdevelop/avalonedit">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- toolbar: split/unified toggle -->
        <Border Grid.Row="0" Background="{DynamicResource Brush.Surface}" Padding="6,3"
                Visibility="{Binding HasContent, Converter={StaticResource Bool2Vis}}">
            <ToggleButton Content="{loc:Tr Diff.Split}" IsChecked="{Binding IsSplit}"
                          HorizontalAlignment="Right" ToolTip="{loc:Tr Diff.SplitTip}"
                          Foreground="{DynamicResource Brush.Text}" Padding="8,2" Cursor="Hand"/>
        </Border>

        <Grid Grid.Row="1">
            <!-- unified -->
            <avalon:TextEditor x:Name="Editor"
                               IsReadOnly="True" FontFamily="Consolas" FontSize="12.5"
                               WordWrap="False" ShowLineNumbers="False"
                               Background="{DynamicResource Brush.Surface}" Foreground="{DynamicResource Brush.Text}"
                               HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto"/>

            <!-- side-by-side -->
            <Grid x:Name="SplitRoot" Visibility="Collapsed">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="1"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <avalon:TextEditor x:Name="LeftEditor" Grid.Column="0"
                                   IsReadOnly="True" FontFamily="Consolas" FontSize="12.5"
                                   WordWrap="False" ShowLineNumbers="False"
                                   Background="{DynamicResource Brush.Surface}" Foreground="{DynamicResource Brush.Text}"
                                   HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto"/>
                <Border Grid.Column="1" Background="{DynamicResource Brush.Border}"/>
                <avalon:TextEditor x:Name="RightEditor" Grid.Column="2"
                                   IsReadOnly="True" FontFamily="Consolas" FontSize="12.5"
                                   WordWrap="False" ShowLineNumbers="False"
                                   Background="{DynamicResource Brush.Surface}" Foreground="{DynamicResource Brush.Text}"
                                   HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto"/>
            </Grid>

            <!-- placeholder -->
            <Border Background="{DynamicResource Brush.Surface}"
                    Visibility="{Binding ShowPlaceholder, Converter={StaticResource Bool2Vis}}">
                <TextBlock Text="{Binding PlaceholderText}" Style="{StaticResource MutedText}"
                           TextWrapping="Wrap" MaxWidth="360"
                           HorizontalAlignment="Center" VerticalAlignment="Center" TextAlignment="Center"/>
            </Border>
        </Grid>
    </Grid>
</UserControl>
