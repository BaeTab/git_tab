<UserControl x:Class="GitTab.App.Controls.DiffView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:avalon="http://icsharpcode.net/sharpdevelop/avalonedit">
    <Grid>
        <avalon:TextEditor x:Name="Editor"
                           IsReadOnly="True"
                           FontFamily="Consolas"
                           FontSize="12.5"
                           WordWrap="False"
                           ShowLineNumbers="False"
                           Background="{DynamicResource Brush.Surface}"
                           Foreground="{DynamicResource Brush.Text}"
                           HorizontalScrollBarVisibility="Auto"
                           VerticalScrollBarVisibility="Auto"
                           Visibility="{Binding HasContent, Converter={StaticResource Bool2Vis}}"/>

        <Border Background="{DynamicResource Brush.Surface}"
                Visibility="{Binding ShowPlaceholder, Converter={StaticResource Bool2Vis}}">
            <TextBlock Text="{Binding PlaceholderText}"
                       Style="{StaticResource MutedText}"
                       TextWrapping="Wrap" MaxWidth="360"
                       HorizontalAlignment="Center" VerticalAlignment="Center"
                       TextAlignment="Center"/>
        </Border>
    </Grid>
</UserControl>
